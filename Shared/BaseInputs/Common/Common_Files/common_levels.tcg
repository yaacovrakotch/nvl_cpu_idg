SpecificationSet d2d_bf_x_x_pkg_lvl_BFUNC (max,min,nom)
{


	Double p_scale_all						    = 1;
	Double vcc_gb_type							= 1,-1,0;


	Voltage tester_gb_lc						= __shared__::_UserVars.uv_lc_vcc_gb*vcc_gb_type*__shared__::_UserVars.cl_qa_flag;
    Voltage tester_gb_hc						= __shared__::_UserVars.uv_hc_vcc_gb*vcc_gb_type*__shared__::_UserVars.cl_qa_flag;


	Voltage p_vnnaon_spec                =  __shared__::PowerSpec.vnnaon_max,         __shared__::PowerSpec.vnnaon_min,        __shared__::PowerSpec.vnnaon_nom;
	Voltage p_vccio_spec                 =  __shared__::PowerSpec.vccio_max,          __shared__::PowerSpec.vccio_min,         __shared__::PowerSpec.vccio_nom;
	Voltage p_v1p8_spec                  =  __shared__::PowerSpec.v1p8_max,           __shared__::PowerSpec.v1p8_min,          __shared__::PowerSpec.v1p8_nom;
	Voltage p_vccgt_spec                 =  __shared__::PowerSpec.vccgt_max,          __shared__::PowerSpec.vccgt_min,         __shared__::PowerSpec.vccgt_nom;
	Voltage p_vdd2_spec                  =  __shared__::PowerSpec.vdd2_max,           __shared__::PowerSpec.vdd2_min,          __shared__::PowerSpec.vdd2_nom;
	Voltage p_vccsa_spec                 =  __shared__::PowerSpec.vccsa_max,          __shared__::PowerSpec.vccsa_min,         __shared__::PowerSpec.vccsa_nom;
	Voltage p_vccia_spec                 =  __shared__::PowerSpec.vccia_max,          __shared__::PowerSpec.vccia_min,         __shared__::PowerSpec.vccia_nom;
	Voltage p_vccdftpcd_spec             =  __shared__::PowerSpec.vccdftpcd_max      ,__shared__::PowerSpec.vccdftpcd_min    , __shared__::PowerSpec.vccdftpcd_nom     ;
	Voltage p_ddrterm_spec               =  __shared__::PowerSpec.ddrterm_max        ,__shared__::PowerSpec.ddrterm_min      , __shared__::PowerSpec.ddrterm_nom       ;
	Voltage p_vccrtc_spec                =  __shared__::PowerSpec.vccrtc_max         ,__shared__::PowerSpec.vccrtc_min       , __shared__::PowerSpec.vccrtc_nom        ;
	Voltage p_vddq_spec                  =  __shared__::PowerSpec.vddq_max         ,  __shared__::PowerSpec.vddq_min       ,   __shared__::PowerSpec.vddq_nom        ;
	Voltage p_vcclpcore_spec             =  __shared__::PowerSpec.vcclpcore_max    ,  __shared__::PowerSpec.vcclpcore_min  ,   __shared__::PowerSpec.vcclpcore_nom        ;
	

	Voltage c_vccgt_prog                 = (p_vccgt_spec     * p_scale_all) + tester_gb_hc;   ##HC
	Voltage c_vdd2_prog                  = (p_vdd2_spec      * p_scale_all) + tester_gb_hc;   ##HC
	Voltage c_vccsa_prog                 = (p_vccsa_spec     * p_scale_all) + tester_gb_hc;   ##HC
	Voltage c_vccia_prog                 = (p_vccia_spec     * p_scale_all) + tester_gb_hc;   ##HC
	Voltage c_vccio_prog                 = (p_vccio_spec     * p_scale_all) + tester_gb_hc;   ##HC
	Voltage c_vnnaon_prog                = (p_vnnaon_spec    * p_scale_all) + tester_gb_hc;   ##HC
	Voltage c_vcclpcore_prog             = (p_vcclpcore_spec * p_scale_all) + tester_gb_hc;   ##HC
	
	Voltage c_vccdftpcd_prog             = (p_vccdftpcd_spec * p_scale_all) + tester_gb_lc;   #LC
	Voltage c_ddrterm_prog               = (p_ddrterm_spec   * p_scale_all) + tester_gb_lc;   #LC
	Voltage c_vddq_prog                  = (p_vddq_spec      * p_scale_all) + tester_gb_lc;   #LC
	Voltage c_vnnaon_fltr_h_prog         = (p_vnnaon_spec    * p_scale_all) + tester_gb_lc;   #LC
	Voltage c_vccio_fltr_h_prog          = (p_vccio_spec     * p_scale_all) + tester_gb_lc;   #LC
	Voltage c_v1p8_prog                  = (p_v1p8_spec      * p_scale_all) + tester_gb_lc;   #LC


	Voltage c_vccrtc_prog               = p_vccrtc_spec * p_scale_all ;	


	Voltage p_cpu0_bgref_trim            = 0V;
	Voltage p_cpu1_bgref_trim            = 0V;
	Voltage p_gcd_bgref_trim             = 0V;
	Voltage p_hub_bgref_trim             = 0V;
	Voltage p_gcd_hub_bgref_trim         = 0V;


	Voltage c_hvmtestmode_prog			= c_vccio_prog*(__shared__::PowerSpec.hvmtestmode_vih_ratio);
	Voltage c_vccio_ldo_prog		    = 0.9V;

	Current vccia_clamp_hi			            = __shared__::PowerSpec.uv_vccia_clamp_hi;
    Current vnnaon_fltr_clamp_hi                = __shared__::PowerSpec.uv_vnnaon_fltr_clamp_hi;
	Current vnnaon_fltr_h_clamp_hi              = __shared__::PowerSpec.uv_vnnaon_fltr_h_clamp_hi;
    Current vccgt_clamp_hi			            = __shared__::PowerSpec.uv_vccgt_clamp_hi;
	Current vccgt_clamp_lo			            = __shared__::PowerSpec.uv_vccgt_clamp_lo;
    Current vccsa_clamp_hi			            = __shared__::PowerSpec.uv_vccsa_clamp_hi;
    Current vnnaon_clamp_hi			            = __shared__::PowerSpec.uv_vnnaon_clamp_hi;
    Current vccio_clamp_hi			            = __shared__::PowerSpec.uv_vccio_clamp_hi;
    Current vccio_fltr_clamp_hi                 = __shared__::PowerSpec.uv_vccio_fltr_clamp_hi;
	Current vccio_fltr_h_clamp_hi               = __shared__::PowerSpec.uv_vccio_fltr_h_clamp_hi;
    Current vdd2_clamp_hi			            = __shared__::PowerSpec.uv_vdd2_clamp_hi;
    Current v1p8_clamp_hi                       = __shared__::PowerSpec.uv_v1p8_clamp_hi;
    Current v1p8_cpu_clamp_hi                   = __shared__::PowerSpec.uv_v1p8_cpu_clamp_hi;
    Current v1p8_fltr_clamp_hi                  = __shared__::PowerSpec.uv_v1p8_fltr_clamp_hi;
    Current v1p8_fltra_clamp_hi                 = __shared__::PowerSpec.uv_v1p8_fltra_clamp_hi;
    Current v1p8_fltrb_clamp_hi                 = __shared__::PowerSpec.uv_v1p8_fltrb_clamp_hi;
    Current vccio_out_svid_clamp_hi             = __shared__::PowerSpec.uv_vccio_out_svid_clamp_hi;
    Current vccdftpcd_clamp_hi                  = __shared__::PowerSpec.uv_vccdftpcd_clamp_hi;
    Current cpu0_ext_bgref_trim_ana_clamp_hi    = __shared__::PowerSpec.uv_cpu0_ext_bgref_trim_ana_clamp_hi;
    Current cpu1_ext_bgref_trim_ana_clamp_hi    = __shared__::PowerSpec.uv_cpu1_ext_bgref_trim_ana_clamp_hi;
    Current hub_ext_bgref_trim_ana_clamp_hi     = __shared__::PowerSpec.uv_hub_ext_bgref_trim_ana_clamp_hi;
    Current gcd_ext_bgref_trim_ana_clamp_hi     = __shared__::PowerSpec.uv_gcd_ext_bgref_trim_ana_clamp_hi;
    Current gcd_hub_ext_bgref_trim_ana_clamp_hi = __shared__::PowerSpec.uv_gcd_hub_ext_bgref_trim_ana_clamp_hi;
    Current ddr_term_clamp_hi                   = __shared__::PowerSpec.uv_ddr_term_clamp_hi;
    Current vddq_clamp_hi                       = __shared__::PowerSpec.uv_vddq_clamp_hi;
    Current vccfpgm_cpu0_0_clamp_hi             = __shared__::PowerSpec.uv_vccfpgm_cpu0_0_clamp_hi;
    Current vccfpgm_cpu0_1_clamp_hi             = __shared__::PowerSpec.uv_vccfpgm_cpu0_1_clamp_hi;
    Current vccfpgm_cpu1_0_clamp_hi             = __shared__::PowerSpec.uv_vccfpgm_cpu1_0_clamp_hi;
    Current vccfpgm_cpu1_1_clamp_hi             = __shared__::PowerSpec.uv_vccfpgm_cpu1_1_clamp_hi;
    Current vccfpgm_gcd_clamp_hi                = __shared__::PowerSpec.uv_vccfpgm_gcd_clamp_hi;
    Current vccfpgm_hub_clamp_hi                = __shared__::PowerSpec.uv_vccfpgm_hub_clamp_hi;
    Current vccfpgm_pcd_ext_nom_clamp_hi        = __shared__::PowerSpec.uv_vccfpgm_pcd_ext_nom_clamp_hi;
    Current vccfpgm_pcd_ext_ehv_clamp_hi        = __shared__::PowerSpec.uv_vccfpgm_pcd_ext_ehv_clamp_hi;
    Current vccfpgm_pcd_osse_ehv_clamp_hi       = __shared__::PowerSpec.uv_vccfpgm_pcd_osse_ehv_clamp_hi;
    Current vccfpgm_pcd_osse_nom_clamp_hi       = __shared__::PowerSpec.uv_vccfpgm_pcd_osse_nom_clamp_hi;



	#CPU setup



	Voltage c_cpu_all_1_vcc_tstprt_prog			= c_vnnaon_prog;
	Voltage c_cpu_all_1_vcc_tap_prog			= c_vnnaon_prog;
	
	Voltage c_cpu_all_vcc_tstprt_prog			= c_vnnaon_prog;
	Voltage c_cpu_all_vcc_tap_prog				= c_vnnaon_prog;


	#===================== CPU1 ===============================
	
	Double p_cpu_all_1_vnnaon_vih_ratio				= 1;
	Double p_cpu_all_1_vnnaon_vil_ratio				= 0;
	Double p_cpu_all_1_vnnaon_vox_ratio				= 0.5;
