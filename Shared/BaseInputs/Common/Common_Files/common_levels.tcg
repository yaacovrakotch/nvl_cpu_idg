	Double p_cpu_all_1_tap_tck_vil_ratio			= 0;
	Double p_cpu_all_1_tap_tck_vox_ratio			= 0.5;
	Double p_cpu_all_1_tap_tms_vih_ratio			= 1;
	Double p_cpu_all_1_tap_tms_vil_ratio			= 0;
	Double p_cpu_all_1_tap_tms_vox_ratio			= 0.5;
