	Voltage p_cpu_all_1_vnnaon_vil_offset			= 0V;
	Voltage p_cpu_all_1_vnnaon_vox_offset			= 0V;
	Voltage p_cpu_all_1_vccio_vih_offset			= 0V;
	Voltage p_cpu_all_1_vccio_vil_offset			= 0V;
	Voltage p_cpu_all_1_vccio_vox_offset			= 0V;
