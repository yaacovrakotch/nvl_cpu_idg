UserVars TP_KNOB
{
	Integer Bin69_FLG = 0;
	String CACHEREP = "ON";
	String COLD = "OFF";
	String DFF_AUTO = "OFF";
	String DIE = "XCC";
	String DIE_PKG = "XCCSP";
	String DOWNSTREAM_SOCKET = "OFF'";
	String DTS_TRIM = "ON";
	String EDC = "OFF";
	String FIVR_FUNC = "ON";
	String FIVR_TRIM = "ON";
	String FULL_CONTENT = "0";
	String FULLFLOW = "ON";
	String IS_FUSING_SOCKET = "FALSE";
	String KILLDB = "TRUE";
	String MCP = "FALSE";
	String PER_PIN = "OFF";
	String PKG = "EP";
	String PLATFORM = "HDMT";
	String PLL_TRIM = "ON";
	String QA = "FALSE";
	String QUAL = "OFF";
	String STEP = "A";
	String TEMPERATURE = "HOT";
	String TEST_SOCKET = "CLASS";
	String THERMAL_PROFILE = "OFF";
	String UPS_CALC = "ON";
	String VMINSEARCH = "ON";
	String VMINTYPE = "VMIN";
}

UserVars TPChassis
{
	String MajorRev = "01D";
	String MinorRev = "00";
	String Platform = "HDMT";
	String ReleaseRev = "Rev49";
	String ReleaseURL = "https://wiki.ith.intel.com/display/IntelTPWiki/Class+HDMx+Rev49";
	String SortClass = "CLASS";
}

SelectorRuleCollection GlobalRule
{
	SelectorRule If_ahmt_fc(yes, default)
	{
		yes => __shared__::SCVars.SC_LOCN == "6168" || __shared__::SCVars.SC_LOCN == "5168";
		default;
	}
	SelectorRule If_Parallel(yes_mv_tp_value, default)
	{
		#yes_mv_tp_value => (contains(LocationSets.CH_CHVM, "[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]") || contains(LocationSets.CSM_CHVM, "[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]")) && !(startsWith(SCVars.SC_ENGID,"Q")) && (SCVars.SC_DIESLCT == "NA" || SCVars.SC_DIESLCT == "");
		yes_mv_tp_value => (contains(LocationSets.CH_CHVM, "[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]")) && !(startsWith(SCVars.SC_ENGID,"Q")) && (SCVars.SC_DIESLCT == "NA" || SCVars.SC_DIESLCT == "");
		default;
	}
	SelectorRule If_ENGTP(yes_mv_tp_value, default)
	{
		yes_mv_tp_value => False;
		default;
	}
    SelectorRule If_18AP(yes, no)
	{
		yes => (((__shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_NVL_S28C" || __shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_NVL_S52C" || __shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_NVL_HX28C" || __shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_NVL_U8C" || __shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_NVL_S8C" || __shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_NVL_UL6C" ||  __shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_DNL_S28C")  && (SCVars.SC_STEP == "A")) || (__shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_NVL_P16C" && SCVars.SC_STEP == "Z"));
		#ext => (((__shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_NVL_S28C" || __shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_NVL_HX28C" || __shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_DNL_S28C") && (SCVars.SC_STEP == "B" || SCVars.SC_STEP == "C")) || (__shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_NVL_AX" && SCVars.SC_STEP == "A") || ((__shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_NVL_H16C" || __shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_NVL_P16C" || __shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_NVL_S16C" || __shared__::GlobalBomGroupName.ActiveBomGroup == "Class_DNL_S16C" || __shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_NVL_AM") && (SCVars.SC_STEP == "A" || SCVars.SC_STEP == "B")));
        #bllc => ((__shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_NVL_S28CB" && SCVars.SC_STEP == "A") || ((__shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_NVL_S52CB" || __shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_DNL_S52CB") && (SCVars.SC_STEP == "B")));
        no;
    }
	SelectorRule If_ProcessType(int, ext, bllc, no)
	{
		int => (((__shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_NVL_S28C" || __shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_NVL_S52C" || __shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_NVL_HX28C" || __shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_NVL_U8C" || __shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_NVL_S8C" || __shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_NVL_UL6C" ||  __shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_DNL_S28C")  && (SCVars.SC_STEP == "A")) || (__shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_NVL_P16C" && SCVars.SC_STEP == "Z"));
		ext => (((__shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_NVL_S28C" || __shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_NVL_HX28C" || __shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_DNL_S28C") && (SCVars.SC_STEP == "B" || SCVars.SC_STEP == "C")) || (__shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_NVL_AX" && SCVars.SC_STEP == "A") || ((__shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_NVL_H16C" || __shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_NVL_U8C" || __shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_NVL_P16C" || __shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_NVL_S16C" || __shared__::GlobalBomGroupName.ActiveBomGroup == "Class_DNL_S16C" || __shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_NVL_AM") && (SCVars.SC_STEP == "A" || SCVars.SC_STEP == "B")));
        bllc => ((__shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_NVL_S28CB" && SCVars.SC_STEP == "A") || ((__shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_NVL_S52CB" || __shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_DNL_S52CB") && (SCVars.SC_STEP == "B")));
        no;
    }
	SelectorRule If_MICP(yes, no)
	{
		yes => __shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_NVL_S28C" || __shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_NVL_S28CB";
		no;
	}
	SelectorRule IsPHM(Outcome1, Outcome2)
	{
		Outcome1 => contains(SCVars.SC_CURRENT_PROCESS_TYPE, "PHM");
		Outcome2;
	}

	SelectorRule IsPHMTiming(Outcome1, Outcome2)
	{
		Outcome1 => contains(SCVars.SC_CURRENT_PROCESS_TYPE, "PHM");
		Outcome2;
	}

	SelectorRule IsPHM_ENG(Outcome1, Outcome2)
	{
		Outcome1 => contains(SCVars.SC_CURRENT_PROCESS_TYPE, "PHM") || contains(LocationSets.FH_ENG,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]") || contains(LocationSets.FC_ENG,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]");
		Outcome2;
	}

	SelectorRule IsVmax(Outcome1, Outcome2)
	{
		Outcome1 => contains(SCVars.SC_CURRENT_PROCESS_TYPE, "PHM");
		Outcome2;
	}

	SelectorRule IsPecGB(Outcome1, Outcome2)
	{
		Outcome1 => contains(SCVars.SC_CURRENT_PROCESS_TYPE, "PHM");
		Outcome2;
	}

	SelectorRule primaryoptype(Outcome1, Outcome2, Outcome3, Outcome4, Outcome5, Outcome6, Outcome7, Outcome8, Outcome9, default)
	{
		Outcome1 => contains(LocationSets.RC_S1, "[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]");
		Outcome2 => contains(LocationSets.PBIC_DAB, "[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]");
		Outcome3 => contains(LocationSets.PBIC_S2, "[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]");
		Outcome4 => contains(LocationSets.FIF_S1, "[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]");
		Outcome5 => contains(LocationSets.FC_S1, "[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]");
		Outcome6 => contains(LocationSets.FC_S2, "[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]");
		Outcome7 => contains(LocationSets.QA_S1, "[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]");
		Outcome8 => contains(LocationSets.EQAM_S1, "[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]");
		Outcome9 => contains(LocationSets.CSM_S1, "[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]");
		default;
	}

	SelectorRule factvars_optype(Outcome1, default)
	{
		Outcome1 => contains(LocationSets.RC_S1, "[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]");
		default;
	}

	SelectorRule FminLimitGuardband(Outcome1, Outcome2, Outcome3)
	{
		Outcome1 =>	contains(LocationSets.CH_QUAL,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]") || contains(LocationSets.CC_QUAL,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]") || contains(LocationSets.CH_QUAL_RV,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]") || contains(LocationSets.CC_QUAL_RV,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]");
		Outcome2 => contains(SCVars.SC_CURRENT_PROCESS_TYPE, "PHM") || contains(LocationSets.FH_ENG,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]") || contains(LocationSets.FC_ENG,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]");
		Outcome3;
	}
}
