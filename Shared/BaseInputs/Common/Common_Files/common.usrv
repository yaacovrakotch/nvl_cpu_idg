Version 1.0;

Shared
{

SelectorRuleCollection BootUp
{
	SelectorRule If_ENGTP(yes_mv_tp_value, default)
	{
		yes_mv_tp_value => False;
		default;
	}
}

SelectorRuleCollection CommonRules
{
	### This rule special for overriding locations/sockets that read PBIC_S2 || Requester: TPI || Usage: DFFVars.READ_OPTYPE uservar
	SelectorRule Override_ReadOptype_PBIC_S2(Outcome1, Outcome2)
	{
		Outcome1 => contains(__shared__::LocationSets.CC_QUAL_RV,"[" + __shared__::SCVars.SC_LOCN + ":" + __shared__::SCVars.SC_CURRENT_PROCESS_TYPE + "]") || contains(__shared__::LocationSets.CC_QUAL,"[" + __shared__::SCVars.SC_LOCN + ":" + __shared__::SCVars.SC_CURRENT_PROCESS_TYPE + "]") || __shared__::SCVars.SC_LOCN == "6233";
		Outcome2;
	}
}

