	### This rule to switch between DS0(Desktop0:i5,i7), DS1 (Desktop1:i9) and M boms in NVL REPO || DS0: S28C, S28CB, S16C || DS1: S52C || M: HX28C, H16C, P16C, U8C, UL6C 
	SelectorRule If_DS0_DS1_M(Outcome1, Outcome2, Outcome3, Outcome4)
	{
		Outcome1 => GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S28C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S28CB" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S16C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_DNL_S28C";
        Outcome2 => GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S52C";
		Outcome3 => GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_HX28C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_H16C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_P16C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_U8C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_UL6C";
		Outcome4;
	}
	
	### This rule to switch between CDIE-48 DS(Desktop0:i5), AX (AX 16C) and M boms in NVL REPO || DS: S16C || AX: AX 16C || M: H16C, P16C
	SelectorRule If_C48_DS_AX_M(Outcome1, Outcome2, Outcome3, Outcome4)
	{
		Outcome1 => GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S16C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_DNL_S16C";
        Outcome2 => GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_AX16C";
		Outcome3 => GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_H16C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_P16C";
		Outcome4;
	}

	SelectorRule IF_S52(Outcome1, Outcome2)
	{
        Outcome1 => GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S52C";
		Outcome2;
	}

	SelectorRule If_M_PKGs(yes, no)
	{
		yes => GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_HX28C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_H16C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_P16C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_U8C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_UL6C";
		no;
	}

	SelectorRule If_HX28C_P16C(Outcome1, Outcome2, Outcome3)
	{
		Outcome1 => GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_HX28C" ;
        Outcome2 => GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_P16C";
		Outcome3;
	}
		SelectorRule If_HX28C_P16C_H16C(HX28C, P16C, H16C,OTHER)
	{
		HX28C => GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_HX28C" ;
        P16C => GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_P16C";
		H16C => GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_H16C";
		OTHER;
	}
	SelectorRule If_S_PKGs(yes, no)
	{
		yes => GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S28C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S52C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S28CB" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S16C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_DNL_S28C";
		no;
	}

	SelectorRule If_PACKAGE(YES, NO)
	{
		YES => GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S28C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S52C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S28CB" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S16C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_DNL_S28C";
		NO => GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_HX28C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_H16C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_P16C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_U8C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_UL6C";
	}
	
	### This rule use for controlling all post fuse locations || Requester: Ching Fang Keh || Usage: Covering all post fuse locations
	SelectorRule If_POSTFUSED (yes, no)
    {
        yes => contains(LocationSets.PHMF,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]") || contains(LocationSets.QA_S1,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]") || contains(LocationSets.CH_QUAL,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]") || contains(LocationSets.CC_QUAL,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]") || contains(LocationSets.FC_ENG,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]") || contains(LocationSets.FH_ENG,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]") || contains(LocationSets.CH_QUAL_RV,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]") || contains(LocationSets.CC_QUAL_RV,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]") || contains(SCVars.SC_LOCN, "6234");
        no;
    }
	
	### this rule enables to check if Dieslct is enabled on not
	SelectorRule Is_Dieslct (no, yes)
    {
        no => contains(SCVars.SC_DIESLCT,"NA");
        yes;
    }
	
	### This rule can be used to for Cdie Dietype 40:Intel 4+0 || 48:Intel 4+8 ||816P:Intel Cdie 8+16  ||816N: N2P Cdie 8+16 ||816BLL: N2P 8+16 bllc 
	SelectorRule If_48(yes, no)
	{
		yes => GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_H16C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_P16C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S16C" ;
		no;
	}
	### This rule can be used to check if the lot name ends with "MV" (MV lot) || Requester: PCH Scan Team || Usage: BypassPort = __shared__::TpRule.If_MV(-1,1);
	SelectorRule If_MV(yes, no)
	{
		yes => endsWith(__shared__::SCVars.SC_LOTNAME,"MV");
		no;
	}
	### This rule is for TPI_DIERCVRY module usage to differentiate CR tracker 
	SelectorRule If_48_40(yes, no)
	{
		yes => GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_H16C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_P16C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S16C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_U8C" ;
		no;
	}
}

### This rule can be used to define dielet combo based on DIELET_INDICATOR || Requester: TPI || Usage: Any condition needs define per dielet(s)
SelectorRuleCollection  DieIndic
{
	### Child rule for CPU dielet
	SelectorRule if_cpu(yes, no) 
	{
	  yes => contains(DieletIndicator.DIELET_INDICATOR, "CPU");
	  no;
	}
	### Child rule for GCD dielet
	SelectorRule if_gcd(yes, no) 
	{
	  yes => contains(DieletIndicator.DIELET_INDICATOR, "GCD");
	  no;
	}
	### Child rule for HUB dielet
	SelectorRule if_hub(yes, no) 
	{
	  yes => contains(DieletIndicator.DIELET_INDICATOR, "HUB");
	  no;
	}
	### Child rule for PCD dielet
	SelectorRule if_pcd(yes, no) 
	{
	  yes => contains(DieletIndicator.DIELET_INDICATOR, "PCD");
	  no;
	}
	### Child rule for Primary ClassHot
	SelectorRule if_primech(yes, no) 
	{
	  yes => contains(LocationSets.CH_HVM,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]")||contains(LocationSets.RCH_HVM,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]");
	  no;
	}
	### Parent rule for define dielet combo
	SelectorRule DieCombo(all, cgh, chp, cgp, ghp, cg, ch, cp, gh, gp, hp, cpu, gcd, hub, pcd, default)
	{
	  all =>  DieIndic.if_cpu(True, False) && DieIndic.if_gcd(True, False) && DieIndic.if_hub(True, False) && DieIndic.if_pcd(True, False);
	  cgh =>  DieIndic.if_cpu(True, False) && DieIndic.if_gcd(True, False) && DieIndic.if_hub(True, False);
	  chp =>  DieIndic.if_cpu(True, False) && DieIndic.if_hub(True, False) && DieIndic.if_pcd(True, False);
	  cgp =>  DieIndic.if_cpu(True, False) && DieIndic.if_gcd(True, False) && DieIndic.if_pcd(True, False);
	  ghp =>  DieIndic.if_gcd(True, False) && DieIndic.if_hub(True, False) && DieIndic.if_pcd(True, False);
	  cg =>   DieIndic.if_cpu(True, False) && DieIndic.if_gcd(True, False);
	  ch =>   DieIndic.if_cpu(True, False) && DieIndic.if_hub(True, False);
	  cp =>   DieIndic.if_cpu(True, False) && DieIndic.if_pcd(True, False);
	  gh =>   DieIndic.if_gcd(True, False) && DieIndic.if_hub(True, False);
	  gp =>   DieIndic.if_gcd(True, False) && DieIndic.if_pcd(True, False);
	  hp =>   DieIndic.if_hub(True, False) && DieIndic.if_pcd(True, False);
	  cpu =>  DieIndic.if_cpu(True, False);
	  gcd =>  DieIndic.if_gcd(True, False);
	  hub =>  DieIndic.if_hub(True, False);
	  pcd =>  DieIndic.if_pcd(True, False);
	  default;
	}

	SelectorRule AllDie(all,default)
	{
	  all =>  DieIndic.if_cpu(True, False) && DieIndic.if_gcd(True, False) && DieIndic.if_hub(True, False) && DieIndic.if_pcd(True, False) && contains(__shared__::LocationSets.CH_CHVM,"[" + __shared__::SCVars.SC_LOCN + ":" + __shared__::SCVars.SC_CURRENT_PROCESS_TYPE + "]");
	  default;
	}

	### This rule special for dummydata only enable in primary sockets|| Requester: TPI || Usage: DummyData module
	SelectorRule If_DummyData(all, cgh, cpu_gcd, cpu_hub, gcd_hub, cpu, gcd, hub, pcd, default) 
	{
	  all => DieIndic.if_cpu(True, False) && DieIndic.if_gcd(True, False) && DieIndic.if_hub(True, False) && DieIndic.if_pcd(True, False) && DieIndic.if_primech(True, False);
      cgh => DieIndic.if_cpu(True, False) && DieIndic.if_gcd(True, False) && DieIndic.if_hub(True, False) && DieIndic.if_primech(True, False);
      cpu_gcd => (DieIndic.if_cpu(True, False) && DieIndic.if_gcd(True, False)) || (DieIndic.if_cpu(True, False) && DieIndic.if_gcd(True, False) && DieIndic.if_pcd(True, False)) && DieIndic.if_primech(True, False);
      cpu_hub => (DieIndic.if_cpu(True, False) && DieIndic.if_hub(True, False)) || (DieIndic.if_cpu(True, False) && DieIndic.if_hub(True, False) && DieIndic.if_pcd(True, False)) && DieIndic.if_primech(True, False);
      gcd_hub => (DieIndic.if_gcd(True, False) && DieIndic.if_hub(True, False)) || (DieIndic.if_gcd(True, False) && DieIndic.if_hub(True, False) && DieIndic.if_pcd(True, False)) && DieIndic.if_primech(True, False);
      cpu => (DieIndic.if_cpu(True, False)) || (DieIndic.if_cpu(True, False) && DieIndic.if_pcd(True, False)) && DieIndic.if_primech(True, False);
      gcd => (DieIndic.if_gcd(True, False)) || (DieIndic.if_gcd(True, False) && DieIndic.if_pcd(True, False)) && DieIndic.if_primech(True, False);
      hub => (DieIndic.if_hub(True, False)) || (DieIndic.if_hub(True, False) && DieIndic.if_pcd(True, False)) && DieIndic.if_primech(True, False);
      pcd => DieIndic.if_pcd(True, False) && DieIndic.if_primech(True, False);
      default;
	}
}

#UserVars TorchRulesVars
#{
#	String locationCode = "6248";
#	#String bom = "394CAB2VB";
#	String bom = (__shared__::TpRule.If_CLASS_NVL_S28C("394AAA2VB","394CAB2VB"));
#}

### This rule controls PUP HERMES test bypass across all socket types.
### Cond 1 (run_both__0__1): PUP enabled at supported CHOT locations (CH_HVM, CH_RV, RCHOT) — run both __0 and __1 plists
### Cond 2 (skip__0_non_pup): ClassHot but the location code is not supported in PUP (FH_ENG / CHM_ENG) — skip __0 plist only.
### Cond 3 (skip__0_downstream): Downstream sockets (CSM & PHM: CCOLD, RCCOLD, PHM) — skip __0 plist.
### Cond 4 (default): Default fallback — also skips the __0 plist.
### Requester: PUP || Usage: BypassPort = __shared__::PUPHERMESRules.PUPSupportedOperation(-1,1,1,-1);
SelectorRuleCollection PUPHERMESRules
{
	SelectorRule PUPSupportedOperation(run_both__0__1, skip__0_non_pup, skip__0_downstream, default)
	{
		run_both__0__1 => contains(LocationSets.CH_HVM,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]") || contains(LocationSets.CH_RV,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]") || contains(LocationSets.RCHOT,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]");
		skip__0_non_pup => contains(LocationSets.FH_ENG,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]") || contains(LocationSets.CHM_ENG,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]");
		skip__0_downstream => contains(LocationSets.CCOLD,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]") || contains(LocationSets.RCCOLD,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]") || contains(LocationSets.PHM,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]");
		default;
	}
}


}

