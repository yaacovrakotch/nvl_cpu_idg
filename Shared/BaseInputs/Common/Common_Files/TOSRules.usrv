	### This rule can be used to apply condition based on either BOM NVLS28C or DNLS28C || Requester: Chan, Jia Huei || Usage: BypassPort = __shared__::TpRule.If_CLASS_NVL_S28C(-1,1);
	SelectorRule If_CLASS_NVL_DNL_S28C(yes, no)
	{
		yes => GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S28C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_DNL_S28C";
		no;
	}
	### This rule to switch between CDIE-40 DS(Desktop0:i5), DNL S8C and M boms in NVL REPO || DS: S8C || DNL: DNL S8C || M: U8C
	SelectorRule If_C40_DS_DNL_M(Outcome1, Outcome2, Outcome3, Outcome4)
	{
		Outcome1 => GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S8C";
		Outcome2 => GetEnvironmentVariable("BOMGROUP") == "CLASS_DNL_S8C";
		Outcome3 => GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_U8C";
		Outcome4;
	}
	### This rule can be used to for Cdie Dietype 40:Intel 4+0
	SelectorRule If_C40(yes, no)
	{
		yes => GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S8C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_DNL_S8C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_U8C" ;
		no;
	}
	### This rule can be used to apply condition based on Benchtop testing || Requester: Huang, Leo || Usage: refer to rule "If_CLASS_NVL_S28C" in this file 
	SelectorRule If_BENCHTOP(yes, no)
	{
		yes => __shared__::SCVars.SC_BENCHTOP == 1;
		no => __shared__::SCVars.SC_BENCHTOP == -1;
	}
	
	### This rule can be used to apply condition based on DIELET_INDICATOR value|| Requester: TPI || Usage: TBD
	SelectorRule If_Dielet(all_die, cpu_gcd_hub, cpu_gcd, cpu_hub, gcd_hub, cpu, gcd, hub, default) 
	{
		all_die => (contains(DieletIndicator.DIELET_INDICATOR, "CPU")) && (contains(DieletIndicator.DIELET_INDICATOR, "HUB")) && (contains(DieletIndicator.DIELET_INDICATOR, "GCD")) && (contains(DieletIndicator.DIELET_INDICATOR, "PCD"));
		cpu_gcd_hub => (((contains(DieletIndicator.DIELET_INDICATOR, "CPU")) && (contains(DieletIndicator.DIELET_INDICATOR, "HUB")) && (contains(DieletIndicator.DIELET_INDICATOR, "GCD")))||((contains(DieletIndicator.DIELET_INDICATOR, "CPU")) && (contains(DieletIndicator.DIELET_INDICATOR, "HUB")) && (contains(DieletIndicator.DIELET_INDICATOR, "GCD"))&& (contains(DieletIndicator.DIELET_INDICATOR, "PCD")))) && (contains(LocationSets.CH_HVM,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]")||contains(LocationSets.RCH_HVM,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]"));
		cpu_gcd => (((contains(DieletIndicator.DIELET_INDICATOR, "CPU")) && (contains(DieletIndicator.DIELET_INDICATOR, "GCD"))&& (contains(DieletIndicator.DIELET_INDICATOR, "PCD")))||((contains(DieletIndicator.DIELET_INDICATOR, "CPU")) && (contains(DieletIndicator.DIELET_INDICATOR, "GCD")))) && (contains(LocationSets.CH_HVM,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]")||contains(LocationSets.RCH_HVM,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]"));
		cpu_hub => (((contains(DieletIndicator.DIELET_INDICATOR, "CPU")) && (contains(DieletIndicator.DIELET_INDICATOR, "HUB")))||((contains(DieletIndicator.DIELET_INDICATOR, "CPU")) && (contains(DieletIndicator.DIELET_INDICATOR, "HUB"))&& (contains(DieletIndicator.DIELET_INDICATOR, "PCD")))) && (contains(LocationSets.CH_HVM,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]")||contains(LocationSets.RCH_HVM,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]"));
		gcd_hub => (((contains(DieletIndicator.DIELET_INDICATOR, "HUB")) &&  (contains(DieletIndicator.DIELET_INDICATOR, "GCD"))&&(contains(DieletIndicator.DIELET_INDICATOR, "PCD")))||((contains(DieletIndicator.DIELET_INDICATOR, "HUB")) &&  (contains(DieletIndicator.DIELET_INDICATOR, "GCD"))))&& (contains(LocationSets.CH_HVM,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]")||contains(LocationSets.RCH_HVM,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]"));
		cpu => (((contains(DieletIndicator.DIELET_INDICATOR, "CPU")) && (contains(DieletIndicator.DIELET_INDICATOR, "PCD")))||(DieletIndicator.DIELET_INDICATOR == "CPU")) && (contains(LocationSets.CH_HVM,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]")||contains(LocationSets.RCH_HVM,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]"));
		gcd => (((contains(DieletIndicator.DIELET_INDICATOR, "GCD")) && (contains(DieletIndicator.DIELET_INDICATOR, "PCD")))||(DieletIndicator.DIELET_INDICATOR == "GCD")) && (contains(LocationSets.CH_HVM,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]")||contains(LocationSets.RCH_HVM,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]"));
		hub => (((contains(DieletIndicator.DIELET_INDICATOR, "HUB")) && (contains(DieletIndicator.DIELET_INDICATOR, "PCD")))||(DieletIndicator.DIELET_INDICATOR == "HUB")) && (contains(LocationSets.CH_HVM,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]")||contains(LocationSets.RCH_HVM,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]"));
		default;
	}
	###This rule is differentiate between IntelProcess and TSMC for FUSE modules
	SelectorRule If_18AP(yes, no)
	{
		yes => (((GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S28C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S52C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_HX28C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_U8C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S8C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_UL6C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_DNL_S28C") && SCVars.SC_STEP == "A") || (GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_P16C" && SCVars.SC_STEP == "Z"));
		#ext => (((GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S28C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_HX28C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_DNL_S28C") && (SCVars.SC_STEP == "B" || SCVars.SC_STEP == "C")) || (GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_AX" && SCVars.SC_STEP == "A") || ((GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_H16C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_P16C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S16C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_DNL_S16C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_AM") && (SCVars.SC_STEP == "A" || SCVars.SC_STEP == "B")));
	    #bllc => ((GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S28CB" && SCVars.SC_STEP == "A") || ((GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S52CB" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S52CB") && SCVars.SC_STEP == "B"));
		no;
	}
	SelectorRule If_ProcessType(int, ext, bllc, no)
	{
		int => (((GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S28C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S52C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_HX28C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_U8C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S8C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_UL6C" ||  GetEnvironmentVariable("BOMGROUP") == "CLASS_DNL_S28C")  && SCVars.SC_STEP == "A") || (GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_P16C" && SCVars.SC_STEP == "Z")); 
	    ext => (((GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S28C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_HX28C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_DNL_S28C") && (SCVars.SC_STEP == "B" || SCVars.SC_STEP == "C")) || (GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_AX" && SCVars.SC_STEP == "A") || ((GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_H16C" ||GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_U8C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_P16C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S16C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_DNL_S16C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_AM") && (SCVars.SC_STEP == "A" || SCVars.SC_STEP == "B")));
	    bllc => ((GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S28CB" && SCVars.SC_STEP == "A") || ((GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S52CB" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S52CB") && SCVars.SC_STEP == "B"));
		no;
	}
	### This rule was ported over from ARL under the SelectorRuleCollection "GlobalRule" || Usage: refer to rule "If_CLASS_NVL_S28C" in this file
	SelectorRule PO_Z_step_bypass (yes, no)
	{
		yes => contains(SCVars.SC_STEP,"Z");
		no;
	}
	
