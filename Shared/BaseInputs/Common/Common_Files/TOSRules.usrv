	{
		yes => contains(LocationSets.CH_CHVM, "[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]") || contains(LocationSets.RCHOT,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]") || contains(LocationSets.CH_CRV ,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]") || SCVars.SC_ENGID == "QE" || SCVars.SC_ENGID == "QZ" ;
		no;
	}
