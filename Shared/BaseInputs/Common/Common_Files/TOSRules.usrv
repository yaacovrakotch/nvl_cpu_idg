		no;
	}
	### This rule can be used to apply condition based on [SC_LOCN]:[SC_CURRENT_PROCESS_TYPE] matching a valid QRE/Qual location set || Requestor: Le, Ly K || Usage: BypassPort = __shared__::TpRule.If_QRE(-1,1);
	SelectorRule If_QRE(yes, no)
	{
		yes =>	contains(LocationSets.CH_QUAL,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]") || contains(LocationSets.CC_QUAL,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]") || contains(LocationSets.CH_QUAL_RV,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]") || contains(LocationSets.CC_QUAL_RV,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]");
		no;
	}
	### This rule can be used to apply condition based on [SC_LOCN]:[SC_CURRENT_PROCESS_TYPE] matching a valid REBI location set || Usage: BypassPort = __shared__::TpRule.If_REBI(-1,1);
	SelectorRule If_REBI(yes, no)
	{
		yes =>	contains(LocationSets.INLINE_REBI_RV,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]");
		no;
	}
	### This rule can be used to apply condition based on BOM || Requester: TPI || Usage: BypassPort = __shared__::TpRule.If_CLASS_NVL_S28C(-1,1);
