Version 1.0;

Shared
{

UserVars DieletIndicator
{
	String DIELET_INDICATOR = "CPU,GCD,HUB,PCD";
}

SelectorRuleCollection TpRule
{

	SelectorRule Check_BOM(Outcome1, Outcome2, Outcome3)
	{
        Outcome1 => GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S52C";
		Outcome2 => GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S28C";
		Outcome3;
	}
	
	 SelectorRule If_NoGTRecovery(CLASS, CH_CHVM, RCHOT, CH_QUAL, default)
    {
        CLASS => GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_HX28C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S28C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S16C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_DNL_S28C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S28CB"  ;
		CH_CHVM => contains(__shared__::LocationSets.CH_CHVM,"[" + __shared__::SCVars.SC_LOCN + ":" + __shared__::SCVars.SC_CURRENT_PROCESS_TYPE + "]");
		RCHOT => contains(__shared__::LocationSets.RCHOT,"[" + __shared__::SCVars.SC_LOCN + ":" + __shared__::SCVars.SC_CURRENT_PROCESS_TYPE + "]");
		CH_QUAL => contains(__shared__::LocationSets.CH_QUAL,"[" + __shared__::SCVars.SC_LOCN + ":" + __shared__::SCVars.SC_CURRENT_PROCESS_TYPE + "]");
		default;
    }
	
	### This rule was ported over from ARL under the SelectorRuleCollection "TpRule" ||  Usage: refer to Fuse module refer
    SelectorRule FuseSpecial(fuse, pbic, rv, fh_eng, fc_eng, default)
    {
        fuse => contains(LocationSets.FUSE,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]");
        pbic => contains(LocationSets.PBIC_DAB,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]");
        rv => contains(LocationSets.RV,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]");
        fh_eng => contains(LocationSets.FH_ENG,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]");
        fc_eng => contains(LocationSets.FC_ENG,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]");
        default;
    }
	### This rule was ported over from ARL under the SelectorRuleCollection "TpRule" ||  Usage: refer to Fuse module 
	SelectorRule FuseRetestBypass(Outcome1, Outcome2, Outcome3, Outcome4, Outcome5, Outcome6, Outcome7, Outcome8, Outcome9, Outcome10, Outcome11, default)
    {
        Outcome1 => contains(LocationSets.FUSE,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]");
        Outcome2 => contains(LocationSets.PBIC_DAB,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]");
        Outcome3 => contains(LocationSets.RV,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]");
        Outcome4 => (contains(LocationSets.FH_ENG,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]") || contains(LocationSets.CH_QUAL,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]"));
        Outcome5 => (contains(LocationSets.FC_ENG,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]") || contains(LocationSets.CC_QUAL,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]"));
        Outcome6 => contains(LocationSets.CC_CHVM,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]") && SCVars.SC_LOCN == "6234";
        Outcome7 => SCVars.SC_CURRENT_PROCESS_TYPE == "PHMHOT" && (SCVars.SC_ENGID == "4R" || SCVars.SC_ENGID == "4P");
        Outcome8 => SCVars.SC_CURRENT_PROCESS_TYPE == "PHMCOLD" && SCVars.SC_ENGID == "4R";
        Outcome9 => SCVars.SC_CURRENT_PROCESS_TYPE == "PHMCOLD" && SCVars.SC_ENGID == "4P";
        Outcome10 => SCVars.SC_CURRENT_PROCESS_TYPE == "PHMROOM" && SCVars.SC_ENGID == "4R";
        Outcome11 => SCVars.SC_CURRENT_PROCESS_TYPE == "PHMROOM" && SCVars.SC_ENGID == "4P";
        default;
    }
	### This rule was ported over from ARL under the SelectorRuleCollection "TpRule". It is used by Fuse to tell the FACT flow we are ready to burn ||  Usage: refer to rule "If_CLASS_NVL_S28C" in this file 
	SelectorRule If_FacilityID_GDL (yes, no)
	{
		yes => contains(SCVars.SC_FACILITYID, "GDL");
		no;
	}
	### This rule was ported over from ARL under the SelectorRuleCollection "TpRule" ||  Usage: refer to rule "If_CLASS_NVL_S28C" in this file 
	SelectorRule If_PHMF (yes, no)
    {
        yes => contains(LocationSets.PHMF,"[" + SCVars.SC_LOCN + ":" + SCVars.SC_CURRENT_PROCESS_TYPE + "]");
        no;
    }
	### This rule can be used to apply condition based on the 32EU GCD config || Usage: refer to rule "If_CLASS_NVL_S28C" in this file 
	SelectorRule If_32EU(yes, no)  ## Subject to enhance when we get i5, i3, BLLC, UL and HX BOM Group names 
	{
		yes => GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S28C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S28CB" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S52C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S16C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_UL6C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_DNL_S28C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_HX28C";
		no;
	}
	### This rule can be used to apply condition based on the 64EU GCD config || Usage: refer to rule "If_CLASS_NVL_S28C" in this file
	SelectorRule If_64EU(yes, no)  
	{
		yes => GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_H16C" || GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_U8C";
		no;
	}
	### This rule can be used to apply condition based on the 192EU GCD config || Usage: refer to rule "If_CLASS_NVL_S28C" in this file 
	SelectorRule If_192EU(yes, no) 
	{
		yes => GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_P16C";
		no;
	}
