ThermalControl ThermalControl_TDYN_9_CPU
{
	ThermalDomainTable
	{
		ThermalDomain = NVL_PWR;
	}
    IPG::VCCGT
    {
    PowerScale=factor;
    }
    IPC::VCCIA
    {
        PowerScale=factor;
    }
    VNNAON
    {
        PowerScale=factor;
    }
    IPH::VCCSA	
    {
        PowerScale=factor;
    }
	IPH::VCCLPECORE	
    {
        PowerScale=factor;
    }
    VCCIO
    {
        PowerScale=factor;
    }
    IPC::TDYN_9_IPC
    {
       SumScale = factor;
    }
}
