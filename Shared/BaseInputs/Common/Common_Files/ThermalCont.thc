Version 1.0;
ThermalMeasure VirtualScs_AllPins_ThermalMeasure
{
	DTS_VirtualSCS_SCGM_INTRADUT
  {
        FilterMin = -10000.0;
        FilterMax = 10000.0;
        ConstantCoefficient = -64.0;
        LinearCoefficient = 0.5;
    }
}
ThermalMeasure ThermalBlock_TDAU_Channel_P_S28C
{
      IPC::CPU_TDAU0
  {
        MeasurementMode     = MeasurementMode_CPU;
        SCOCalMethod      	= SCOCAL_Method_CPU;   
        IdealityFactor      = Ideality_CPU;       
        ForceCurrentFirst   = IC1_CPU;
        ForceCurrentSecond  = IC3_CPU;
        ForceCurrentThird  = IC2_CPU;
        BaseLeakageCompensation = BaseLeakage_CPU;
        Slope           = D_Slope_CPU;
        TemperatureOffset   = Offset_CPU;
  }
      IPG::GCD_TDAU0
  {
        MeasurementMode     = MeasurementMode_GCD;
        SCOCalMethod      	= SCOCAL_Method_GCD;   
        IdealityFactor      = Ideality_GCD;       
        ForceCurrentFirst   = IC1_GCD;
        ForceCurrentSecond  = IC3_GCD;
        ForceCurrentThird  = IC2_GCD;
        BaseLeakageCompensation = BaseLeakage_GCD;
        Slope           = D_Slope_GCD;
        TemperatureOffset   = Offset_GCD;
  }
      IPP::PCD_TDAU0
  {
        MeasurementMode     = MeasurementMode_PCD;
        SCOCalMethod      	= SCOCAL_Method_PCD;   
        IdealityFactor      = Ideality_PCD;       
        ForceCurrentFirst   = IC1_PCD;
        ForceCurrentSecond  = IC3_PCD;
        ForceCurrentThird  = IC2_PCD;
        BaseLeakageCompensation = BaseLeakage_PCD;
        Slope           = D_Slope_PCD;
        TemperatureOffset   = Offset_PCD;
  }
      IPH::HUB_TDAU0
  {
        MeasurementMode     = MeasurementMode_HUB;
        SCOCalMethod      	= SCOCAL_Method_HUB;   
        IdealityFactor      = Ideality_HUB;       
        ForceCurrentFirst   = IC1_HUB;
        ForceCurrentSecond  = IC3_HUB;
        ForceCurrentThird  = IC2_HUB;
        BaseLeakageCompensation = BaseLeakage_HUB;
        Slope           = D_Slope_HUB;
        TemperatureOffset   = Offset_HUB;
  }

}

