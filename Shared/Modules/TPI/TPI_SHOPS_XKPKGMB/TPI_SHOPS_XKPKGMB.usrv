Version 1.0;


SelectorRuleCollection TPI_SHOPS_XKPKGMB_Rules
{
    SelectorRule If_HOT_PHMHOT_COLD_PHMCOLD_FUSE(HOT, PHMHOT, COLD, PHMCOLD, FUSE, default)
    {
        HOT => contains(__shared__::LocationSets.CHOT, "[" + __shared__::SCVars.SC_LOCN + ":" + __shared__::SCVars.SC_CURRENT_PROCESS_TYPE + "]") || contains(__shared__::LocationSets.RCHOT,"[" + __shared__::SCVars.SC_LOCN + ":" + __shared__::SCVars.SC_CURRENT_PROCESS_TYPE + "]");
        PHMHOT => contains(__shared__::LocationSets.PHMHOT, "[" + __shared__::SCVars.SC_LOCN + ":" + __shared__::SCVars.SC_CURRENT_PROCESS_TYPE + "]");
        COLD => contains(__shared__::LocationSets.CCOLD,"[" + __shared__::SCVars.SC_LOCN + ":" + __shared__::SCVars.SC_CURRENT_PROCESS_TYPE + "]") || contains(__shared__::LocationSets.RCCOLD,"[" + __shared__::SCVars.SC_LOCN + ":" + __shared__::SCVars.SC_CURRENT_PROCESS_TYPE + "]");
        PHMCOLD => contains(__shared__::LocationSets.PHMCOLD, "[" + __shared__::SCVars.SC_LOCN + ":" + __shared__::SCVars.SC_CURRENT_PROCESS_TYPE + "]");
        FUSE => contains(__shared__::LocationSets.FUSE, "[" + __shared__::SCVars.SC_LOCN + ":" + __shared__::SCVars.SC_CURRENT_PROCESS_TYPE + "]");
        default;
    }
    SelectorRule If_SAMPLING(ON, OFF)
    {
        ON => contains(__shared__::LocationSets.PHM, "[" + __shared__::SCVars.SC_LOCN + ":" + __shared__::SCVars.SC_CURRENT_PROCESS_TYPE + "]") || contains(__shared__::LocationSets.FUSE,"[" + __shared__::SCVars.SC_LOCN + ":" + __shared__::SCVars.SC_CURRENT_PROCESS_TYPE + "]") || contains(__shared__::SCVars.SC_ENGID, "Q*");
        OFF;
    }
    SelectorRule If_HOT_COLD(HOT, COLD, default)
    {
        HOT => contains(__shared__::LocationSets.HOT,"[" + __shared__::SCVars.SC_LOCN + ":" + __shared__::SCVars.SC_CURRENT_PROCESS_TYPE + "]");
        COLD => contains(__shared__::LocationSets.COLD,"[" + __shared__::SCVars.SC_LOCN + ":" + __shared__::SCVars.SC_CURRENT_PROCESS_TYPE + "]");
        default;
    }
    SelectorRule If_BENCHTOP(YES, NO)
    {
        YES => __shared__::SCVars.SC_BENCHTOP == 1;
        NO => __shared__::SCVars.SC_BENCHTOP == -1;
    }
    SelectorRule If_HVM_FULL(HVM, FULL, default)
    {
        HVM => __shared__::TIU.Type == "HVM";
        FULL => __shared__::TIU.Type == "FULL";
        default;
    }
    SelectorRule If_HW_CONFIG(HX28C, P16C, H16C, U8C, default)
    {
        HX28C => __shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_NVL_HX28C";
        P16C => __shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_NVL_P16C";
        H16C => __shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_NVL_H16C";
        U8C => __shared__::GlobalBomGroupName.ActiveBomGroup == "CLASS_NVL_U8C";
        default;
    }
}

