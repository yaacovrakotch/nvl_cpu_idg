Flow TPI_BASE_XXX_INIT
{
    FlowItem CTRL_X_SCREEN_K_INIT_X_X_X_X_MTLFILE CTRL_X_SCREEN_K_INIT_X_X_X_X_MTLFILE
    {
        Result -2
        {
            Property PassFail = "Fail";
            SetBin b99931000_fail_TPI_BASE_XXX_CTRL_X_SCREEN_K_INIT_X_X_X_X_MTLFILE_n2;
            Return -2;
        }
        Result -1
        {
            Property PassFail = "Fail";
            SetBin b98931000_fail_TPI_BASE_XXX_CTRL_X_SCREEN_K_INIT_X_X_X_X_MTLFILE_n1;
            Return -1;
        }
        Result 0
        {
            Property PassFail = "Fail";
            Return 0;
        }
        Result 1
        {
            Property PassFail = "Pass";
            GoTo CTRL_X_PRIMEINIT_K_INIT_X_X_X_X_LOADPRIME;
        }
        Result 2
        {
            Property PassFail = "Fail";
            Return 0;
        }
    }
    
    FlowItem CTRL_X_PRIMEINIT_K_INIT_X_X_X_X_LOADPRIME CTRL_X_PRIMEINIT_K_INIT_X_X_X_X_LOADPRIME
    {
        Result -2
        {
            Property PassFail = "Fail";
            SetBin b99931001_fail_TPI_BASE_XXX_CTRL_X_PRIMEINIT_K_INIT_X_X_X_X_LOADPRIME_n2;
            Return -2;
        }
        Result -1
        {
            Property PassFail = "Fail";
            SetBin b98931001_fail_TPI_BASE_XXX_CTRL_X_PRIMEINIT_K_INIT_X_X_X_X_LOADPRIME_n1;
            Return -1;
        }
        Result 0
        {
            Property PassFail = "Fail";
            Return 0;
        }
        Result 1
        {
            Property PassFail = "Pass";
            GoTo CTRL_X_UC_K_INIT_X_X_X_X_LOGTPINFOTOTELEMETRY;
        }
    }
    
    FlowItem CTRL_X_UC_K_INIT_X_X_X_X_LOGTPINFOTOTELEMETRY CTRL_X_UC_K_INIT_X_X_X_X_LOGTPINFOTOTELEMETRY
    {
        Result -2
