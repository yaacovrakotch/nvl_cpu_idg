CSharpTest PrimeTdrCalibrationTestMethod CTRL_X_TDRCAL_K_INIT_X_X_X_X_TDRCLIBRATION
{
    AlwaysExecute = "FALSE";
    PinGroups = "all_tdr";
    TdrHiLimit = "16.2E-9S";
    TdrLoLimit = "2.2E-9S";
}

CSharpTest RunCallback CTRL_X_RUNCALLBACK_K_INIT_X_X_X_X_TDRLOG
{
    BypassPort = toInteger(__shared__::SCVars.SC_TDRLOG);
    Callback = "LogFile";
    Parameters = "--directory D:/Calibration --file TDRFile_BB2T4H1P*.txt --altname TDR";
    PostInstance = "WriteUserVar(--uservar __shared__::SCVars.SC_TDRLOG --value 1 --type String)";
}

