{
}

CSharpTest PrimeTiuIdentityTestMethod CTRL_X_XIUIDENTITY_K_INIT_X_X_X_X_XIUNAME
{
    # NVL XIU Name
    ValidElastomerSheetRegex = __shared__::TpRule.If_DS0_DS1_M("I01954L1010E[0-9]*","I01954L1010E[0-9]*","","");
    ValidBottomElastomerSheetRegex = __shared__::TpRule.If_DS0_DS1_M("I01954L1020E[0-9]*","I01954L1020E[0-9]*","","");
ValidTiuRegex = __shared__::TpRule.If_CLASS_NVL_HX28C("^BB2T4H1P[0-9]+:NVLHX[a-zA-Z0-9]+[T|F][0-9]+$",__shared__::TpRule.If_SS_NVL_U8C("^BB2T4H1P[0-9]+:NVLHX[a-zA-Z0-9]+[T|F][0-9]+$", "^BB2T4H1P[0-9]+:NVL[S|A|W|H][L|B][0-9]+[T|F][0-9]+$"));}

