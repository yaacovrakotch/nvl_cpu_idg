CSharpTest PowerSequenceHandler CTRL_X_PWR_K_INIT_X_X_X_X_PWRUPTCDC
{
    # 1st test in the flow, power up 
    ApplyPowerDown = "Always";
    ApplyPowerOn = "Always";
    PowerDownTc = "BASE::Power_dwn_PKG_xxx_pwrd_zerzer";
    PowerOnTc = "BASE::Power_Up_TC_DC_PKG_force_0V_lvl";
}

