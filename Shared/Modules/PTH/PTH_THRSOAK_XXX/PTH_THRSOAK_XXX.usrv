		CLASS_NVL_P16C_ROOM  => contains(__shared__::LocationSets.ROOM,"[" + __shared__::SCVars.SC_LOCN + ":" + __shared__::SCVars.SC_CURRENT_PROCESS_TYPE + "]") && __shared__::_UserVars.UFG_PgmRules_BomGroup=="CLASS_NVL_P16C";
		CLASS_NVL_P16C_FUSE  => contains(__shared__::LocationSets.FUSE,"[" + __shared__::SCVars.SC_LOCN + ":" + __shared__::SCVars.SC_CURRENT_PROCESS_TYPE + "]") && __shared__::_UserVars.UFG_PgmRules_BomGroup=="CLASS_NVL_P16C";
