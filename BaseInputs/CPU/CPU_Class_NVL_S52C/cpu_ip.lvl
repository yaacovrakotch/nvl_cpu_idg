		VIL = c_cpu_all_tstprt_o_data_vil;
		VOX = c_cpu_all_tstprt_o_data_vox;
	}
	CPU_TRST
	{
		FixedDriveState = "Off";
		PinModeSel = "Digital";
		TermMode = "Off";
		VIH = c_cpu_all_tap_trst_vih;
		VIL = c_cpu_all_tap_trst_vil;
		VOX = c_cpu_all_tap_trst_vox;
	}
	CPU_TCK
	{
