		PinModeSel = "Digital";
		TermMode = "Off";
	}
	
	CPU_HVM_TESTMODE  {TermMode = "Off";PinModeSel = "Digital";FixedDriveState="VIH";}
	CPU1_HVM_TESTMODE {TermMode = "Off";PinModeSel = "Digital";FixedDriveState="VIH";}
	
