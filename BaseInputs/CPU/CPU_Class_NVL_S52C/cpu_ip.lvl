		IOH             = c_cpu_all_tap_tdo_ioh;
		IOL             = c_cpu_all_tap_tdo_iol;
	}
	
	
	SequenceBreak 0mS;
	CPU_RST_00 #xx_cpu_hvm_epd_on
	{
		FixedDriveState = p_cpu_all_epd_on_FixedDriveState;
		PinModeSel = "Digital";
		TermMode = "Off";
	}
	CPU_RST_01 #xx_cpu_hvm_cold_boot_trigger
	{
		FixedDriveState = p_cpu_all_cbt_FixedDriveState;
		PinModeSel = "Digital";
		TermMode = "Off";
