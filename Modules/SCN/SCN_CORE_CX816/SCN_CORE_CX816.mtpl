CSharpTest PrimePatConfigTestMethod CTRL_X_PATMOD_K_INIT_X_X_X_X_GLOBAL_INIT
{
    BypassPort = -1;
    ConfigurationFile = GetEnvironmentVariable("~HDMT_TP_BASE_DIR") + "./Modules/SCN/SCN_CORE_CX816/InputFiles/dummy.setpoints.json";
    SetPoint = "scancoredummy";
}

CSharpTest RunCallback CTRL_X_UF_E_INIT_X_X_X_X_PINMAP_SCN_PRIME_DIERECOVERY
{
    BypassPort = -1;
    Callback = "LoadPinMapFile";
    Parameters = "--decoder AnyFailSingleSliceDecoder --file ./Modules/SCN/SCN_CORE_CX816/Inputfiles/DieRecoveryPinMaps_IO_NVL_SCNCORE.json";
}

CSharpTest RunCallback CTRL_X_UF_E_INIT_X_X_X_X_PINMAP_SCN_PRIME_OCCSA_DIERECOVERY
{
    BypassPort = -1;
    Callback = "LoadPinMapFile";
    Parameters = __shared__::TpRule.If_DS0_DS1_M("--decoder FailDataDecoder --file ./Modules/SCN/SCN_CORE_CX816/InputFiles/DieRecoveryPinMaps_OCC_NVL_SCNCORE_N2P.json", "--decoder FailDataDecoder --file ./Modules/SCN/SCN_CORE_CX816/InputFiles/DieRecoveryPinMaps_OCC_NVL_SCNCORE.json", "--decoder FailDataDecoder --file ./Modules/SCN/SCN_CORE_CX816/InputFiles/DieRecoveryPinMaps_OCC_NVL_SCNCORE_N2P.json", "--decoder FailDataDecoder --file ./Modules/SCN/SCN_CORE_CX816/InputFiles/DieRecoveryPinMaps_OCC_NVL_SCNCORE_N2P.json");
}

CSharpTest RunCallback CTRL_X_UF_E_INIT_X_X_X_X_PINMAP_SCN_PRIME_OCCAS_DIERECOVERY
{
    BypassPort = -1;
    Callback = "LoadPinMapFile";
    Parameters = __shared__::TpRule.If_DS0_DS1_M("--decoder FailDataDecoder --file ./Modules/SCN/SCN_CORE_CX816/InputFiles/DieRecoveryPinMaps_OCC_NVL_AS_SCNCORE_N2P.json", "--decoder FailDataDecoder --file ./Modules/SCN/SCN_CORE_CX816/InputFiles/DieRecoveryPinMaps_OCC_NVL_AS_SCNCORE.json", "--decoder FailDataDecoder --file ./Modules/SCN/SCN_CORE_CX816/InputFiles/DieRecoveryPinMaps_OCC_NVL_AS_SCNCORE_N2P.json", "--decoder FailDataDecoder --file ./Modules/SCN/SCN_CORE_CX816/InputFiles/DieRecoveryPinMaps_OCC_NVL_AS_SCNCORE_N2P.json");
}

CSharpTest RunCallback CTRL_X_UF_E_INIT_X_X_X_X_SCNCORE_APEXTC
{
    BypassPort = __shared__::TpRule.If_DS0_DS1_M(-1, -1, BYPASS_PARAMETER.APEXTC_BYPASS, 1);
    Callback = "ReadFrequencyPatConfigFile";
    Parameters = __shared__::TpRule.If_DS0_DS1_M(GetEnvironmentVariable("~HDMT_TP_BASE_DIR") + "./Modules/SCN/SCN_CORE_CX816/InputFiles/ApexTC_Input_Config_N2P.json", GetEnvironmentVariable("~HDMT_TP_BASE_DIR") + "./Modules/SCN/SCN_CORE_CX816/InputFiles/ApexTC_Input_Config.json", GetEnvironmentVariable("~HDMT_TP_BASE_DIR") + "./Modules/SCN/SCN_CORE_CX816/InputFiles/ApexTC_Input_Config_N2P.json", GetEnvironmentVariable("~HDMT_TP_BASE_DIR") + "./Modules/SCN/SCN_CORE_CX816/InputFiles/ApexTC_Input_Config_N2P.json");
}

CSharpTest VminTC CHAIN_CORE_SB_K_BEGINCPU_X_CR_NOM_X_F1_M0
{
    Patlist = __shared__::TpRule.If_DS0_DS1_M("scn_cdie_begincpu_m0_allchain_1hot_ssn400_edt_classhvm_list","scn_cdie_begincpu_m0_allchain_1hot_ssn400_edt_classhvm_list","scn_cdie_begincpu_m0_allchain_1hot_ssn400_edt_classhvm_list","scn_cdie_begincpu_m0_allchain_1hot_ssn400_edt_classhvm_list");
    LevelsTc = __shared__::TpRule.If_DS0_DS1_M("SCN_CORE_CX816::cpu_all_bf_x_x_ipc_lvl_CPU_BFUNC_SCNCORE_OVERRIDE_nom","SCN_CORE_CX816::cpu_all_bf_x_x_ipc_lvl_CPU_BFUNC_SCNCORE_OVERRIDE_nom","SCN_CORE_CX816::cpu_all_bf_x_x_ipc_lvl_CPU_BFUNC_SCNCORE_OVERRIDE_nom","SCN_CORE_CX816::cpu_all_bf_x_x_ipc_lvl_CPU_BFUNC_SCNCORE_OVERRIDE_nom");
    TimingsTc = __shared__::TpRule.If_DS0_DS1_M("SCN_CORE_CX816::cpu_hvm_timing_mts1500_tstprtclk750_tck93p75_B0OVERRIDE1500","SCN_CORE_CX816::cpu_fun_timing_mts800_tstprtclk400_tck100_OVERRIDE800","SCN_CORE_CX816::cpu_hvm_timing_mts1500_tstprtclk750_tck93p75_HXB0OVERRIDE1500","SCN_CORE_CX816::cpu_hvm_timing_mts1500_tstprtclk750_tck93p75_HXB0OVERRIDE1500");
    BaseNumbers = "13000";
    BypassPort = -1;
    EndVoltageLimits = "0.9";
    ExecutionMode = "SearchWithScoreboard";
    FailCaptureCount = toInteger(999);
    FeatureSwitchSettings = "fivr_mode_on,disable_masked_targets,print_per_target_increments,print_scoreboard_counters";
    FivrCondition = "NOM_CCF_CORE";
    ForwardingMode = "InputOutput";
    InitialMaskBits = "1110";
    LogLevel = "Disabled";
    MaskPins = "";
    MaxFailsNum = toInteger(__shared__::Specs.VMX_MAX_FAILS);
    PatternNameCounterIndexes = "1,2,3,4,5,6,7";
    PinMap = "CORE_SCAN";
    PostInstance = "";
    PreInstance = "";
    RecoveryMode = "RecoveryPort";
    RecoveryOptions = __shared__::Recovery_Single.F1F4_recovery_opt_CR;
    RecoveryTrackingIncoming = "CR";
    RecoveryTrackingOutgoing = "CR";
    ScoreboardEdgeTicks = toInteger(__shared__::Specs.VMX_EDGE_TICK);
    SetPointsPlistMode = "Local";
    SetPointsPlistParamName = "Patlist";
    SetPointsPostInstance = PSPOST.CR_F1;
    SetPointsPreInstance = PSPRE.CR_F1+","+"MCdrv:corefreq:"+__shared__::FlowMatrixSingular.CR_F1_FREQ+"GHz";
    StartVoltages = "0.9";
    StepSize = toDouble(0.01);
    TestMode = "MultiVmin";
    VoltageConverter = "--dlvrpins VCCIA --expressions " + DROPOUT.CR_F1;
    VoltageTargets = "CORE3,CORE2,CORE1,CORE0";
}

