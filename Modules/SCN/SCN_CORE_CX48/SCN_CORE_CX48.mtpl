CSharpTest PrimePatConfigTestMethod CTRL_X_PATMOD_K_INIT_X_X_X_X_GLOBAL_INIT
{
    BypassPort = -1;
    ConfigurationFile = GetEnvironmentVariable("~HDMT_TP_BASE_DIR") + "./Modules/SCN/SCN_CORE_CX48/InputFiles/dummy.setpoints.json";
    SetPoint = "scancoredummy";
}

CSharpTest RunCallback CTRL_X_UF_E_INIT_X_X_X_X_PINMAP_SCN_PRIME_DIERECOVERY
{
    BypassPort = -1;
    Callback = "LoadPinMapFile";
    Parameters = "--decoder AnyFailSingleSliceDecoder --file ./Modules/SCN/SCN_CORE_CX48/Inputfiles/DieRecoveryPinMaps_IO_NVL_SCNCORE.json";
}

CSharpTest RunCallback CTRL_X_UF_E_INIT_X_X_X_X_PINMAP_SCN_PRIME_OCCSA_DIERECOVERY
{
    BypassPort = -1;
    Callback = "LoadPinMapFile";
    Parameters = "--decoder FailDataDecoder --file ./Modules/SCN/SCN_CORE_CX48/InputFiles/DieRecoveryPinMaps_OCC_NVL_SCNCORE_N2P.json";
}

CSharpTest RunCallback CTRL_X_UF_E_INIT_X_X_X_X_PINMAP_SCN_PRIME_OCCAS_DIERECOVERY
{
    BypassPort = -1;
    Callback = "LoadPinMapFile";
    Parameters = "--decoder FailDataDecoder --file ./Modules/SCN/SCN_CORE_CX48/InputFiles/DieRecoveryPinMaps_OCC_NVL_AS_SCNCORE_N2P.json";
}

CSharpTest RunCallback CTRL_X_UF_E_INIT_X_X_X_X_SCNCORE_APEXTC
{
    BypassPort = -1;
    Callback = "ReadFrequencyPatConfigFile";
    Parameters = GetEnvironmentVariable("~HDMT_TP_BASE_DIR") + "./Modules/SCN/SCN_CORE_CX48/InputFiles/ApexTC_Input_Config_N2P.json";
}

CSharpTest VminTC CHAIN_CORE_SB_K_BEGINCPU_X_CR_NOM_X_F1_M0
{
    Patlist = "scn_cdie_begincpu_m0_allchain_1hot_ssn400_edt_classhvm_list";
    LevelsTc = "SCN_CORE_CX48::cpu_all_bf_x_x_ipc_lvl_CPU_BFUNC_SCNCORE_OVERRIDE_nom";
    TimingsTc = __shared__::TpRule.If_C48_DS_AX_M("SCN_CORE_CX48::cpu_hvm_timing_mts1500_tstprtclk750_tck93p75_N2P48S16COVERRIDE1500","SCN_CORE_CX48::cpu_hvm_timing_mts1500_tstprtclk750_tck93p75_N2P48S16COVERRIDE1500","SCN_CORE_CX48::cpu_hvm_timing_mts1500_tstprtclk750_tck93p75_N2P48OVERRIDE1500","SCN_CORE_CX48::cpu_hvm_timing_mts1500_tstprtclk750_tck93p75_N2P48S16COVERRIDE1500");
    BaseNumbers = "13000";
    BypassPort = -1;
    EndVoltageLimits = "0.9";
    ExecutionMode = "SearchWithScoreboard";
    FailCaptureCount = toInteger(999);
    FeatureSwitchSettings = "fivr_mode_on,disable_masked_targets,print_per_target_increments,print_scoreboard_counters";
    FivrCondition = "NOM_CCF_CORE";
    ForwardingMode = "InputOutput";
    InitialMaskBits = "10";
    LogLevel = "Disabled";
    MaskPins = "";
    MaxFailsNum = toInteger(__shared__::Specs.VMX_MAX_FAILS);
    PatternNameCounterIndexes = "1,2,3,4,5,6,7";
    PinMap = "CORE1_SCAN,CORE0_SCAN";
    PostInstance = "";
    PreInstance = "";
    RecoveryMode = "RecoveryPort";
    RecoveryOptions = __shared__::Recovery_Single.F1F4_recovery_opt_CR;
    RecoveryTrackingIncoming = __shared__::RecoveryTracker.INCOMING_CR;
    RecoveryTrackingOutgoing = __shared__::RecoveryTracker.OUTGOING_CR;
    ScoreboardEdgeTicks = toInteger(__shared__::Specs.VMX_EDGE_TICK);
    SetPointsPlistMode = "Local";
    SetPointsPlistParamName = "Patlist";
    SetPointsPostInstance = PSPOST.CR_F1;
    SetPointsPreInstance = PSPRE.CR_F1+","+"MCdrv:corefreq:"+__shared__::FlowMatrixSingular.CR_F1_FREQ+"GHz";
    StartVoltages = "0.9";
    StepSize = toDouble(0.01);
    TestMode = "MultiVmin";
    VoltageConverter = "--dlvrpins VCCIA --expressions " + DROPOUT.CR_F1;
    VoltageTargets = "CORE1,CORE0";
}

