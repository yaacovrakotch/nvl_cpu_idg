CSharpTest RunCallback CTRL_X_UF_E_INIT_X_X_X_X_SCNUNCORE_APEXTC
{
    BypassPort = __shared__::TpRule.If_C48_DS_AX_M(1, 1, 1, 1);
    Callback = "ReadFrequencyPatConfigFile";
    Parameters = GetEnvironmentVariable("~HDMT_TP_BASE_DIR") + "./Modules/SCN/SCN_UNCORE_CX48/InputFiles/ApexTC_Input_Config.json";
}

CSharpTest PrimePatConfigTestMethod CTRL_X_PATMOD_K_INIT_X_X_X_X_GLOBAL_INIT
{
    BypassPort = 1;
    ConfigurationFile = "./Modules/SCN_UNCORE_CX48/inputfiles/SCN_UNCORE_INIT.setpoints.json";
    SetPoint = "scanuncorepatmod";
    SetPointsPreInstance = "";
}

CSharpTest DDGShmooTC STUCKAT_UNCORE_SHMOO_E_BEGINCPU_X_X_NOM_X
{
    # NOCLEAN
    # PATLIST_NOCLEAN : Due to needing this plist for PO shmoo
    # TCG_NOCLEAN : Due to needing it
    Patlist = "scn_cdie_begin_full_atpg_all_edt_classhvm_list";
    LevelsTc = __shared__::TpRule.If_C48_DS_AX_M("SCN_UNCORE_CX48::cpu_all_bf_x_x_ipc_lvl_CPU_BFUNC_SCNUNCOREB0_OVERRIDE_nom","SCN_UNCORE_CX48::cpu_all_bf_x_x_ipc_lvl_CPU_BFUNC_SCNUNCORE_OVERRIDE_nom","SCN_UNCORE_CX48::cpu_all_bf_x_x_ipc_lvl_CPU_BFUNC_SCNUNCOREB0_OVERRIDE_nom","SCN_UNCORE_CX48::cpu_all_bf_x_x_ipc_lvl_CPU_BFUNC_SCNUNCORE_OVERRIDE_nom");
    TimingsTc = __shared__::TpRule.If_C48_DS_AX_M("SCN_UNCORE_CX48::cpu_hvm_timing_mts1500_tstprtclk750_tck93p75_OVERRIDEDS","SCN_UNCORE_CX48::cpu_hvm_timing_mts1500_tstprtclk750_tck93p75_OVERRIDE","SCN_UNCORE_CX48::cpu_hvm_timing_mts1500_tstprtclk750_tck93p75_OVERRIDE","SCN_UNCORE_CX48::cpu_hvm_timing_mts1500_tstprtclk750_tck93p75_OVERRIDE");
    BypassPort = 1;
    LogLevel = "Enabled";
    PrintFormat = "ShmooHub";
    SetPointsPlistMode = "Local";
    SetPointsPlistParamName = "Patlist";
    SetPointsPreInstance = PSPRE.CLR_F1+","+"MCdrv:ringfreq_0:"+__shared__::FlowMatrixSingular.CCF_F1_FREQ+"GHz";
    VoltageConverter = "--dlvrpins VCCIA --expressions CCF --fivrcondition NOM_CCF";
    XAxisParam = __shared__::TpRule.If_C48_DS_AX_M("all_mts","all_mts","all_mts","all_mts");
    XAxisParamType = "UserDefined";
    XAxisRange = __shared__::TpRule.If_C48_DS_AX_M("1100e6:100e6:5","600e6:100e6:5","1100e6:100e6:5","600e6:100e6:5");
    XAxisType = "SpecSetVariable";
    YAxisParam = "CCF";
    YAxisParamType = "UserDefined";
    YAxisRange = "1.2:-0.1:10";
    YAxisType = "FIVR";
}

