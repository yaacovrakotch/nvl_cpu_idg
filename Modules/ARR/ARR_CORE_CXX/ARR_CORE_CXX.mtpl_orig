MultiTrialTest ARR_ATOM_VMIN_K_FMINXAT_HITO_VCCIA_FMIN_X_COMBINED
{
    TrialVariable CPU_TRIALS::FlowDomain.ATOM;
    TrialVariableExitAction "Continue";
	CSharpTrialTest VminTC "ARR_ATOM_VMIN_K_FMINXAT_HITO_VCCIA_FMIN_" + __shared__::CustomFlowMatrixSpecs.AT_FMIN_MHz + "_COMBINED"
    {
        Patlist = "IPC::arr_cdie_fminxat_pbist_atom_all_all_vatom_reducedks_srh_all_fmin_hptp800_class_list";
        LevelsTc = "CPU_IP_BASE::cpu_all_bf_x_x_ipc_lvl_min";
        TimingsTc = ARR_ATOM_CXX.timings_Rules_fmin;
        BaseNumbers = "__BNUM__";
        #BypassPort = __shared__::TpRule.If_CLASS_NVL_S28C("1","-1");
        BypassPort = -1;
        DtsConfiguration = ARR_ATOM_CXX_Rules.TPRules(ARR_ATOM_CXX.dtsconfig_s28cn2p,ARR_ATOM_CXX.dtsconfig_s52c,ARR_ATOM_CXX.dtsconfig_hx28c,ARR_ATOM_CXX.dtsconfig_48c,ARR_ATOM_CXX.dtsconfig_48c,ARR_ATOM_CXX.dtsconfig_48c,ARR_ATOM_CXX.dtsconfig_s28cn2p,ARR_ATOM_CXX.dtsconfig_s52c);
        CornerIdentifiers = __shared__::TpRule.If_48("AT1@F1,AT0@F1","AT3@F1,AT2@F1,AT1@F1,AT0@F1");
        #LimitGuardband = toString(__shared__::GBVars.FminLimitGuardband);
        LimitGuardband = toString(__shared__::TpRule.If_QRE("",toString(__shared__::GBVars.FminLimitGuardband)));
        EndVoltageLimits = __shared__::FlowMatrixSingular.AT_LFM_VMIN_RAIN_KILL;
        ExecutionMode = "SearchWithScoreboard";
        FeatureSwitchSettings = "disable_masked_targets,fivr_mode_on,print_per_target_increments,print_scoreboard_counters";
        FivrCondition = "NOM";
        TrialParam FlowIndex = __shared__::FlowMatrix.FlowIndex;
        ForwardingMode = "Input";
        MaxFailsNum = toInteger(__shared__::Specs.CHK_MAX_FAILS);
        PatternNameCounterIndexes = "9,10,11,12,13,14,15";
        PinMap = "NVL_ARRATOM";
        RecoveryMode = "NoRecovery";
        RecoveryOptions = __shared__::Recovery_Single.F1F4_recovery_opt_AT;
        RecoveryTrackingIncoming = ARR_ATOM_CXX_Rules.TPRules(ARR_ATOM_CXX.rectrack_others,ARR_ATOM_CXX.rectrack_others,ARR_ATOM_CXX.rectrack_others,ARR_ATOM_CXX.rectrack_s16c,ARR_ATOM_CXX.rectrack_s16c,ARR_ATOM_CXX.rectrack_s16c,ARR_ATOM_CXX.rectrack_others,ARR_ATOM_CXX.rectrack_others);
        RecoveryTrackingOutgoing = ARR_ATOM_CXX_Rules.TPRules(ARR_ATOM_CXX.rectrack_others,ARR_ATOM_CXX.rectrack_others,ARR_ATOM_CXX.rectrack_others,ARR_ATOM_CXX.rectrack_s16c,ARR_ATOM_CXX.rectrack_s16c,ARR_ATOM_CXX.rectrack_s16c,ARR_ATOM_CXX.rectrack_others,ARR_ATOM_CXX.rectrack_others);
        ScoreboardEdgeTicks = toInteger(__shared__::Specs.CHK_EDGE_TICK);
        SetPointsPlistParamName = "Patlist";
        SetPointsPreInstance = "MCdrv:atomfreq_0:"+__shared__::FlowMatrixSingular.AT_FMIN+"GHz,MCdrv:ringfreq_0:"+__shared__::FlowMatrixSingular.AT_FMIN+"GHz,MCAarr:ratio_modify:"+__shared__::FlowMatrixSingular.AT_FMIN+"GHz";
        StartVoltages = __shared__::TpRule.If_48("ATOMM1_F1_VMIN,ATOMM0_F1_VMIN","ATOMM3_F1_VMIN,ATOMM2_F1_VMIN,ATOMM1_F1_VMIN,ATOMM0_F1_VMIN");
        StartVoltagesForRetry = __shared__::QNRTpRuleShared.If_PseudoVminForwarding(__shared__::QNRUsrvShared.StartVoltagesForRetry , "");
        StartVoltagesOffset = __shared__::QNRTpRuleShared.If_PseudoVminForwarding(__shared__::QNRUsrvShared.StartVoltagesOffset , "");
        StepSize = toDouble(__shared__::FlowMatrixSingular.AT_SEARCH_RESOLUTION);
        TestMode = "MultiVmin";
        VoltageConverter = ARR_ATOM_CXX_Rules.TPRules(ARR_ATOM_CXX.volcon_pmux_vmin_others,ARR_ATOM_CXX.volcon_pmux_vmin_others,ARR_ATOM_CXX.volcon_pmux_vmin_others,ARR_ATOM_CXX.volcon_pmux_vmin_s16c,ARR_ATOM_CXX.volcon_pmux_vmin_s16c,ARR_ATOM_CXX.volcon_pmux_vmin_s16c,ARR_ATOM_CXX.volcon_pmux_vmin_others,ARR_ATOM_CXX.volcon_pmux_vmin_others);
        VoltageTargets = ARR_ATOM_CXX_Rules.TPRules(ARR_ATOM_CXX.voltarget_others,ARR_ATOM_CXX.voltarget_others,ARR_ATOM_CXX.voltarget_others,ARR_ATOM_CXX.voltarget_s16c,ARR_ATOM_CXX.voltarget_s16c,ARR_ATOM_CXX.voltarget_s16c,ARR_ATOM_CXX.voltarget_others,ARR_ATOM_CXX.voltarget_others);
        TrialResult -2
        {
            PassFail Fail;
            TrialAction "Exit";
            Return -2;
        }
        TrialResult -1
        {
            PassFail Fail;
            TrialAction "Exit";
            Return -1;
        }
        TrialResult 0
        {
            PassFail Fail;
            TrialAction __shared__::TpRule.MTT_Rule("Next","Exit");
            Return 0;
        }
        TrialResult 1
        {
            PassFail Pass;
            TrialAction "Exit";
            Return 1;
        }
        TrialResult 2
        {
            PassFail Fail;
            TrialAction __shared__::TpRule.MTT_Rule("Next","Exit");
            Return 2;
        }
        TrialResult 3
        {
            PassFail Fail;
            TrialAction __shared__::TpRule.MTT_Rule("Next","Exit");
            Return 3;
        }
        TrialResult 4
        {
            PassFail Fail;
            TrialAction __shared__::TpRule.MTT_Rule("Next","Exit");
            Return 4;
        }
        TrialResult 5
        {
            PassFail Fail;
            TrialAction __shared__::TpRule.MTT_Rule("Next","Exit");
            Return 5;
        }
    }
}


