    BypassPort = ARR_ATOM_CXX_Rules.TPRules(__shared__::TpRule.If_QRE(-1,1),1,1,__shared__::TpRule.If_QRE(-1,1),1,1,1,1);
    ConfigurationFile = "./InputFiles/816/B0/CTVToken_ATOM.json";
    CtvCapturePins = "CPU_TDO";
    ExpectedBits = 1156;
    LogMode = "ALWAYS";
    PrePlist = "VoltageConverter(--overrides ATOM0:ATOMM0_F2_VMIN_ECCON_L2DATA --dlvrpins VCCIA --fivrcondition NOM)";
