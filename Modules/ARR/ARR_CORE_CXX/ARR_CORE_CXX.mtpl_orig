CSharpTest CtvTokensTC ARR_ATOM_VMIN_E_F2XAT_HITO_VCCIA_F2_X_ECCSBFDV_L2_DATA
{
    Patlist = "arr_cdie_f2xat_pbist_atom_directds_ssa_vatom_dected_eccsbfdv_l2_data_galcol_f2_m0_tito_class_list";
    LevelsTc = "CPU_IP_BASE::cpu_all_bf_x_x_ipc_lvl_min";
