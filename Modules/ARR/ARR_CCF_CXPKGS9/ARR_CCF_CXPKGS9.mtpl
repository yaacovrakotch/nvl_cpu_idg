MultiTrialTest LSA_CCF_VMIN_K_LTTCCPU_X_X_F5_3600_LLCRF_MTT
{
    TrialVariable CPU_TRIALS::FlowDomain.RING_TOP;
    TrialVariableExitAction "Continue";
	CSharpTrialTest VminTC "LSA_CCF_VMIN_K_LTTCCPU_X_X_" + __shared__::Corners.CCF_C5 + "_" + __shared__::FreqInMHZ.CCF_C5 + "_LLCRF"
    {
        Patlist = "IPC::arr_cdie_f5xccf_mbist_ccf_all_llc_lsa_vccring_limiter_f5_class_hptp_lttc_list_master";
        LevelsTc = "IPC::ARR_CCF_CXPKGS9::arr_cpu_all_bf_x_x_ipc_lvl_CPU_BFUNC_ARR_MBIST_min_lvl";
        TimingsTc = "IPC::ARR_CCF_CXPKGS9::cpu_fun_timing_mts800_tstprtclk400_tck100_ccfarrmts800";
        BaseNumbers = "12333";
        BypassPort = -1;
		CornerIdentifiers = "";
        #TrialParam CornerIdentifiers = __shared__::CornerIdentifiers.CCF_C5;
        DtsConfiguration = ARR_CCF_CXPKGS9_Specs.dtsconfig_ctv;
        TrialParam EndVoltageLimits = "D.R"+__shared__::Corners.CR_C5+"CCF";
        ExecutionMode = "SearchWithScoreboard";
        FeatureSwitchSettings = ARR_CCF_CXPKGS9_Specs.FeatureSwitchNonMTT;
        FivrCondition = ARR_CCF_CXPKGS9_Specs.FivrConditionNom;
        FailCaptureCount = toInteger(1);
        FlowIndex = __shared__::FlowMatrixSingular.FlowIndex;
        ForwardingMode = ARR_CCF_CXPKGS9_Specs.ForwardingMode_EDC;
		LimitGuardband = "31mV";
        #LimitGuardband = toString(__shared__::GBVars.LimitGuardband);
        PatternNameCounterIndexes = ARR_CCF_CXPKGS9_Specs.PatternMap;
        RecoveryMode = "NoRecovery";
        RecoveryOptions = "CLASS_NVL_S52C_12C";
        RecoveryTrackingIncoming = "SLC0_B,SLC0";
        RecoveryTrackingOutgoing = "SLC0_B,SLC0";
        PinMap = "CCF_2CDIE_SLC0_B,CCF_2CDIE_SLC0";
        ScoreboardEdgeTicks = toInteger(__shared__::Specs.CHK_EDGE_TICK);
		MaxFailsNum = toInteger(__shared__::Specs.CHK_MAX_FAILS);
        SetPointsPlistParamName = "Patlist";
        SetPointsPostInstance = PSPOST.CLR_F5+ "," + ARR_CCF_CXPKGS9_Specs.nbl_on;
        TrialParam SetPointsPreInstance = PSPRE.CLR_F5+","+"MCdrv:"+ARR_CCF_CXPKGS9_Specs.corefreq+":"+ __shared__::FlowMatrixSingular.CR_F1_FREQ+"GHz,MCdrv:"+ARR_CCF_CXPKGS9_Specs.ringfreq+":"+ __shared__::FreqValues.CCF_C5+"GHz,MCdrv:atomfreq_0:"+__shared__::FlowMatrixSingular.AT_F1_FREQ+"GHz";
        TrialParam StartVoltages = "D.R"+__shared__::Corners.CR_C5+"CCF";
        TrialParam StartVoltagesForRetry = __shared__::QNRTpRuleShared.If_PseudoVminForwarding(__shared__::QNRUsrvShared.StartVoltagesForRetryF5 , ["","",""]);
        TrialParam StartVoltagesOffset = __shared__::QNRTpRuleShared.If_PseudoVminForwarding(__shared__::QNRUsrvShared.StartVoltagesOffsetF5 , ["","",""]);
        StepSize = toDouble(__shared__::FlowMatrixSingular.CR_SEARCH_RESOLUTION);
        TestMode = "MultiVmin";
        VoltageTargets = "CCF1,CCF";
        VoltageConverter =  ARR_CCF_CXPKGS9_Specs.VoltageConverter_rail + DROPOUT.CLR_F5;
       TrialResult -2
        {
            PassFail Fail;
            TrialAction "Exit";
            Return -2;
        }
        TrialResult -1
        {
            PassFail Fail;
            TrialAction "Exit";
            Return -1;
        }
        TrialResult 0
        {
            PassFail Fail;
            TrialAction "Exit";
            Return 0;
        }
        TrialResult 1
        {
            PassFail Pass;
            TrialAction "Exit";
            Return 1;
        }
        TrialResult 2
        {
            PassFail Fail;
            TrialAction "Exit";
            Return 2;
        }
        TrialResult 3
        {
            PassFail Fail;
            TrialAction "Exit";
            Return 3;
        }
        TrialResult 4
        {
            PassFail Fail;
            TrialAction "Exit";
            Return 4;
        }
        TrialResult 5
        {
            PassFail Fail;
            TrialAction "Exit";
            Return 5;
        }
    }
}

