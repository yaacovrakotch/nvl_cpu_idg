	Const String timing_dnls28c = "IPC::ARR_UNCORE_CXX::cpu_hvm_timing_mts400_tstprtclk200_tck50_dnls28c";
	Const String hxb0_hvmtiming = "IPC::ARR_UNCORE_CXX::cpu_hvm_timing_mts400_tstprtclk200_tck50_hxb0";
	Const String hxb0_400_hvmtiming = "IPC::ARR_UNCORE_CXX::cpu_hvm_timing_mts400_tstprtclk200_tck50_pncarrmts400_hxb0";
	Const String timing_48 = "IPC::ARR_UNCORE_CXX::cpu_hvm_timing_mts400_tstprtclk200_tck50_pncarrmts400_T0";
	Const String timing_others = "IPC::ARR_UNCORE_CXX::cpu_fun_timing_mts800_tstprtclk400_tck100_uncarrmts800";
	Const String timing_PMTM = "IPC::CPU_IP_BASE::cpu_hvm_timing_mts800_tstprtclk400_tck100";
	Const String timing_dnls28c_PMTM = "IPC::ARR_UNCORE_CXX::cpu_hvm_timing_mts800_tstprtclk400_tck100_dnls28c";
	Const String timing_48_S16 = "IPC::ARR_UNCORE_CXX::cpu_hvm_timing_mts400_tstprtclk200_tck50_pncarrmts400_T0_S16";

	
	String timingRules = ARR_UNCORE_Rules.TPRules(ARR_UNCORE_CKX_Specs.timing_s28c,ARR_UNCORE_CKX_Specs.timing_others,ARR_UNCORE_CKX_Specs.hxb0_400_hvmtiming,ARR_UNCORE_CKX_Specs.timing_48,ARR_UNCORE_CKX_Specs.timing_48_S16,ARR_UNCORE_CKX_Specs.timing_48,ARR_UNCORE_CKX_Specs.timing_s28c,ARR_UNCORE_CKX_Specs.timing_others);
	String repair_timingRules = ARR_UNCORE_Rules.TPRules(ARR_UNCORE_CKX_Specs.timing_s28c,ARR_UNCORE_CKX_Specs.timing_PMTM,ARR_UNCORE_CKX_Specs.timing_s28c,ARR_UNCORE_CKX_Specs.timing_48,ARR_UNCORE_CKX_Specs.timing_48,ARR_UNCORE_CKX_Specs.timing_48,ARR_UNCORE_CKX_Specs.timing_s28c,ARR_UNCORE_CKX_Specs.timing_PMTM);
	String HRY_LIST_Rules = ARR_UNCORE_Rules.TPRules(ARR_UNCORE_CKX_Specs.HRY_LIST_816,ARR_UNCORE_CKX_Specs.HRY_LIST_others,ARR_UNCORE_CKX_Specs.HRY_LIST_816,ARR_UNCORE_CKX_Specs.HRY_LIST_48,ARR_UNCORE_CKX_Specs.HRY_LIST_48,ARR_UNCORE_CKX_Specs.HRY_LIST_48,ARR_UNCORE_CKX_Specs.HRY_LIST_816,ARR_UNCORE_CKX_Specs.HRY_LIST_others);
	String dffmapRules = ARR_UNCORE_Rules.TPRules(ARR_UNCORE_CKX_Specs.dffmap_s28c,ARR_UNCORE_CKX_Specs.dffmap_others,ARR_UNCORE_CKX_Specs.dffmap_s28c,ARR_UNCORE_CKX_Specs.dffmap_48,ARR_UNCORE_CKX_Specs.dffmap_48,ARR_UNCORE_CKX_Specs.dffmap_48,ARR_UNCORE_CKX_Specs.dffmap_s28c,ARR_UNCORE_CKX_Specs.dffmap_others);
	String DTSConfig_Rules = ARR_UNCORE_Rules.TPRules(ARR_UNCORE_CKX_Specs.dtsconfig_s28cn2p,ARR_UNCORE_CKX_Specs.dtsconfig_s52c,ARR_UNCORE_CKX_Specs.dtsconfig_s28cn2p, ARR_UNCORE_CKX_Specs.dtsconfig_48c,ARR_UNCORE_CKX_Specs.dtsconfig_48c,ARR_UNCORE_CKX_Specs.dtsconfig_48c,ARR_UNCORE_CKX_Specs.dtsconfig_s28cn2p,ARR_UNCORE_CKX_Specs.dtsconfig_s28cn2p);
