	Const String DTSConfig = "nvl_cpu816_all";
	Const String PatternMap = "9,10,11,12,13,14,15";
	Const String dtsconfig_hx28c = "ALL_CDIE_S28C";
	Const String dtsconfig_s28cn2p = "ALL_CDIE_S28C_N2P";
	Const String dtsconfig_s52c = "ALL_CDIE_S52C";
	Const String dtsconfig_48c = "ALL_CDIE_C48_N2P_NONE_CORE";
	Const String dtsconfig_ctv = "nvl_cpu_all_ctv";
	Const String dtsconfig_noctv = "nvl_cpu_all_noctv";
