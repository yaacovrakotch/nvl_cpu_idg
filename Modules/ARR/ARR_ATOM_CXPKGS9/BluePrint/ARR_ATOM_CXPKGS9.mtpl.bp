CSharpTest ApexTC ARR_ATOM_VMIN_E_F5XAT_HITO_VCCIA_X_X_L2DATA_APEXTC
{
    Patlist = "IPC::arr_cdie_f5xat_pbist_atom_directdsdb_ssa_vatom_reducedks_\ssa_array_type\_f5_hptp800_class_master";
    LevelsTc = "CPU_IP_BASE::cpu_all_bf_x_x_ipc_lvl_min";
    TimingsTc = "IPC::ARR_ATOM_CXPKGS9::cpu_fun_timing_mts800_tstprtclk400_tck100_arratom";
    BypassPort = -1;
    DtsConfiguration = "";
    End = __shared__::FlowMatrixSingular.APEX_ATOM_MIN;
    FivrCondition = "NOM";
    ForwardingMode = "Input";
    InitialMaskBits = "";
    PatternNameCounterIndexes = "9,10,11,12,13,14,15";
    PinMap = "NVL_ARRATOM";
    RecoveryOptions = "";
    StepSize = 3;
    RecoveryTracking = "ACRM3_B,ACRM2_B,ACRM1_B,ACRM0_B,ACRM3,ACRM2,ACRM1,ACRM0";
    SetPointsPlistParamName = "Patlist";
    Start = __shared__::FlowMatrixSingular.APEX_ATOM_MAX;
    #StepSize = 1;
    SetPointsPreInstance = "MCdrv:atomfreq_0:3.2GHz,MCdrv:corefreq:3.2GHz,MCdrv:ringfreq_0:3.1GHz,MCAarr:ratio_modify:3.2GHz";
    SetPointsPostInstance = "CDIE_ATOM:nblctrl_cdie_atom_l2:nblon,CDIE_ATOM:nblctrl1_cdie_atom_l2:nblon";
    ExportTokens = "FXATC7_L2D,FXATC6_L2D,FXATC5_L2D,FXATC4_L2D,FXATC3_L2D,FXATC2_L2D,FXATC1_L2D,FXATC0_L2D";
    Targets = "ARR_ATOM31,ARR_ATOM21,ARR_ATOM11,ARR_ATOM01,ARR_ATOM3,ARR_ATOM2,ARR_ATOM1,ARR_ATOM0";
    VoltageConverter = "--dlvrpins VCCIA --railconfigurations CDIE_L2_NBLCTRL0 CDIE_L2_NBLCTRL1 CDIE_L2_NBLCTRL2 CDIE_L2_NBLCTRL3 CDIE1_L2_NBLCTRL0 CDIE1_L2_NBLCTRL1 CDIE1_L2_NBLCTRL2 CDIE1_L2_NBLCTRL3 --overrides ATOM31:1.1,ATOM21:1.1,ATOM11:1.1,ATOM01:1.1 ATOM3:1.1,ATOM2:1.1,ATOM1:1.1,ATOM0:1.1";
}

