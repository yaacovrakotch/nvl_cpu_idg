CSharpTest PrimeLSARasterTestMethod LSA_ATOM_HRY_E_BEGINCPUNOM_TITO_X_MIN_X_R
{
	Patlist = "arr_cdie_x_pbist_atom_indir_lsa_repairable_vatom_hry_all_\freq_corner\_tito_class_list";
	LevelsTc = "CPU_IP_BASE::cpu_all_bf_x_x_ipc_lvl_min";
	TimingsTc = "CPU_IP_BASE::cpu_fun_timing_mts100_tstprtclk50_tck100";
	#BypassPort = -1;
