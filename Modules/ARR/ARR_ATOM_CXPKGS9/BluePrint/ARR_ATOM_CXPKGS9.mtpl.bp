CSharpTest VminTC ARR_ATOM_SB_K_BEGINCPUNOM_HITO_VCCIA_\FREQ_CORNER\_X_\COVERAGE_TYPE\
{
    Patlist = "IPC::arr_cdie_begincpunom_pbist_atom_all_all_vatom_ks_all_\freq_corner\_hptp800_class_list";
    LevelsTc = "CPU_IP_BASE::cpu_all_bf_x_x_ipc_lvl_min";
    TimingsTc = "IPC::ARR_ATOM_CXPKGS9::cpu_fun_timing_mts800_tstprtclk400_tck100_arratom";
    BaseNumbers = "12500";
    BypassPort = -1;
    EndVoltageLimits = "0.9";
    FeatureSwitchSettings = "disable_masked_targets,fivr_mode_on,print_per_target_increments,print_scoreboard_counters";
    FivrCondition = "NOM";
    ForwardingMode = "InputOutput";
    MaxFailsNum = 0;
    PatternNameCounterIndexes = "9,10,11,12,13,14,15";
    PinMap = "NVL_ARRATOM";
    RecoveryMode = "RecoveryPort";
    RecoveryOptions = __shared__::Recovery_Single.F1F4_recovery_opt_AT;
    RecoveryTrackingIncoming = "ACRM3_B,ACRM2_B,ACRM1_B,ACRM0_B,ACRM3,ACRM2,ACRM1,ACRM0";
    RecoveryTrackingOutgoing = "ACRM3_B,ACRM2_B,ACRM1_B,ACRM0_B,ACRM3,ACRM2,ACRM1,ACRM0";
    ScoreboardEdgeTicks = 0;
    SetPointsPlistParamName = "Patlist";
    SetPointsPreInstance = "MCdrv:atomfreq_0:"+__shared__::FlowMatrixSingular.AT_\FREQ_CORNER\_FREQ+"GHz,MCdrv:corefreq:"+__shared__::FlowMatrixSingular.AT_\FREQ_CORNER\_FREQ+"GHz,MCdrv:ringfreq_0:"+__shared__::FlowMatrixSingular.AT_\FREQ_CORNER\_FREQ+"GHz,MCAarr:ratio_modify:"+__shared__::FlowMatrixSingular.AT_\FREQ_CORNER\_FREQ+"GHz";
    StartVoltages = "0.9";
