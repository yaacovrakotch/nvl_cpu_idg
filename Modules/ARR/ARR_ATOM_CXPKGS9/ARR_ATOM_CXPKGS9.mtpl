CSharpTest VminTC ARR_ATOM_SB_K_BEGINCPUNOM_HITO_VCCIA_F3_X_COMBINED
{
    Patlist = "IPC::arr_cdie_begincpunom_pbist_atom_all_all_vatom_ks_all_f3_hptp800_class_list";
    LevelsTc = "CPU_IP_BASE::cpu_all_bf_x_x_ipc_lvl_min";
