	ExecutionMode = "PRESCREEN";
	HryMapPath = GetEnvironmentVariable("~HDMT_TP_BASE_DIR") + "/Modules/ARR/ARR_ATOM_CXPKGS9/InputFiles/arr_cdie_x_pbist_atom_indir_lsa_repairable_vatom_hry_all_f1_tito_class_list.xml";
