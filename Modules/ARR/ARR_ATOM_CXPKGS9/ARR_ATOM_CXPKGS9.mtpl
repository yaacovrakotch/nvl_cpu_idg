CSharpTest PrimeLSARasterTestMethod LSA_ATOM_HRY_E_BEGINCPUNOM_TITO_X_MIN_X_R
{
	Patlist = "arr_cdie_x_pbist_atom_indir_lsa_repairable_vatom_hry_all_f1_tito_class_list";
