# Sample VminTC test with MTT
MultiTrialTest ARR_ATOM_VMIN_K_FMINXAT_HITO_VCCIA_FMIN_X_SSA_L2DATA_FMIN_FF_SEARCH
{
    TrialVariable CPU_TRIALS::FlowDomain.ATOM;
    TrialVariableExitAction "Restore";
    CSharpTrialTest VminTC "ARR_ATOM_VMIN_K_FMINXAT_HITO_VCCIA_FMIN_" + __shared__::CustomFlowMatrixSpecs.AT_FMIN_MHz + "_SSA_L2DATA_FMIN_FF_SEARCH"
    {
        Patlist = "IPC::arr_cdie_fminxat_pbist_atom_directdsdb_ssa_vatom_reducedks_l2_data_fmin_hptp800_class_list";
        LevelsTc = "CPU_IP_BASE::cpu_all_bf_x_x_ipc_lvl_min";
        TimingsTc = "IPC::CPU_IP_BASE::cpu_fun_timing_mts400_tstprtclk200_tck50";
        BaseNumbers = "12529";
        BypassPort = -1;
        CornerIdentifiers = "";
        EndVoltageLimits = __shared__::FlowMatrixSingular.AT_LFM_VMIN_RAIN_KILL;
        ExecutionMode = "SearchWithScoreboard";
        FeatureSwitchSettings = "disable_masked_targets,fivr_mode_on,print_per_target_increments,print_scoreboard_counters";
        FivrCondition = "NOM";
        TrialParam FlowIndex = __shared__::FlowMatrix.FlowIndex;
        ForwardingMode = "Input";
        #LimitGuardband = __shared__::GBVars.FminLimitGuardband;
        LimitGuardband = "";
        MaxFailsNum = toInteger(__shared__::Specs.CHK_MAX_FAILS);
        PatternNameCounterIndexes = "9,10,11,12,13,14,15";
        PinMap = "NVL_ARRATOM";
        RecoveryMode = "NoRecovery";
        RecoveryOptions = __shared__::Recovery_Single.F1F4_recovery_opt_AT;
        RecoveryTrackingIncoming = "ACRM3_B,ACRM2_B,ACRM1_B,ACRM0_B,ACRM3,ACRM2,ACRM1,ACRM0";
        RecoveryTrackingOutgoing = "ACRM3_B,ACRM2_B,ACRM1_B,ACRM0_B,ACRM3,ACRM2,ACRM1,ACRM0";
        ScoreboardEdgeTicks = toInteger(__shared__::Specs.CHK_EDGE_TICK);
        SetPointsPlistParamName = "Patlist";
        SetPointsPreInstance = "MCdrv:atomfreq_0:"+__shared__::FlowMatrixSingular.AT_FMIN+"GHz,MCdrv:corefreq:"+__shared__::FlowMatrixSingular.AT_FMIN+"GHz,MCdrv:ringfreq_0:"+__shared__::FlowMatrixSingular.AT_FMIN+"GHz,MCAarr:ratio_modify:"+__shared__::FlowMatrixSingular.AT_FMIN+"GHz";
        StartVoltages = __shared__::FlowMatrixSingular.AT_LOW_SEARCH_VALUE;
        StartVoltagesForRetry = __shared__::QNRTpRuleShared.If_PseudoVminForwarding(__shared__::QNRUsrvShared.StartVoltagesForRetry , "");
        StartVoltagesOffset = __shared__::QNRTpRuleShared.If_PseudoVminForwarding(__shared__::QNRUsrvShared.StartVoltagesOffset , "");
        StepSize = toDouble(__shared__::FlowMatrixSingular.AT_SEARCH_RESOLUTION);
        TestMode = "MultiVmin";
        #SetPointsPostInstance = "CDIE_ATOM:nblctrl_cdie_atom_l2:nblon,CDIE_ATOM:nblctrl1_cdie_atom_l2:nblon";
        SetPointsPostInstance = "MCdrv:atomfreq_0:"+__shared__::FlowMatrixSingular.AT_F1_FREQ+"GHz,MCdrv:ringfreq_0:"+ __shared__::FlowMatrixSingular.CCF_F1_FREQ+"GHz,MCAarr:ratio_modify:"+__shared__::FlowMatrixSingular.AT_F1_FREQ+"GHz,MCdrv:pwrmux_sel_atom_l2_0:vcclogic,CDIE_ATOM:nblctrl_cdie_atom_l2:nblon,CDIE_ATOM:nblctrl1_cdie_atom_l2:nblon";
        VoltageConverter = "--railconfigurations CDIE_L2_NBLCTRL0 CDIE_L2_NBLCTRL1 CDIE_L2_NBLCTRL2 CDIE_L2_NBLCTRL3 CDIE1_L2_NBLCTRL0 CDIE1_L2_NBLCTRL1 CDIE1_L2_NBLCTRL2 CDIE1_L2_NBLCTRL3 --dlvrpins VCCIA --expressions " + DROPOUT.AT_FMIN;
       VoltageTargets = "ATOM31,ATOM21,ATOM11,ATOM01,ATOM3,ATOM2,ATOM1,ATOM0";
        TrialResult -2
        {
            PassFail Fail;
            TrialAction "Exit";
            Return -2;
        }
        TrialResult -1
        {
            PassFail Fail;
            TrialAction "Exit";
            Return -1;
        }
        TrialResult 0
        {
            PassFail Fail;
            TrialAction "Exit";
            Return 0;
        }
        TrialResult 1
        {
            PassFail Pass;
            TrialAction "Exit";
            Return 1;
        }
        TrialResult 2
        {
            PassFail Fail;
            TrialAction "Exit";
            Return 2;
        }
        TrialResult 3
        {
            PassFail Pass;
            TrialAction "Exit";
            Return 1;
        }
        TrialResult 4
        {
            PassFail Fail;
            TrialAction "Exit";
            Return 4;
        }
        TrialResult 5
        {
            PassFail Fail;
            TrialAction "Exit";
            Return 5;
        }
    }
}

