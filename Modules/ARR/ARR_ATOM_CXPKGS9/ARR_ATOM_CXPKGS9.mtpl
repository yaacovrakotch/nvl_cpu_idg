	OutputTag = "ATOMLSARasterTagRMIN";
	PinMappingSetName = "ATOM_ALL";
	PrescreenHryFlowToken = "CORE_NOM";
	PrescreenHryFrequencyToken = "10";
	PrescreenMafLimit = 500;
	PrescreenMapName = "LSA_CORERF_ATOMRMIN";
	PrescreenPrintMode = "CTVMODE";
	RasterConfigPath = GetEnvironmentVariable("~HDMT_TP_BASE_DIR") + "/Modules/ARR/ARR_ATOM_CXPKGS9/InputFiles/NVL_VminRasterConfigATOM.json";
	SetPointsPlistParamName = "Patlist";
