    },
    {
      "name": "COVERAGE_TYPE",
      "description": "Coverage variant for array tests: COMBINED=all arrays, SSA_L2DATA=L2 data arrays. CXX has no SSA or MEC standalone coverage.",
      "values": ["COMBINED", "SSA_L2DATA"],
      "replacements": [
        {"find": "_SSA_L2DATA", "replace": "_\\COVERAGE_TYPE\\"},
        {"find": "_COMBINED", "replace": "_\\COVERAGE_TYPE\\"}
      ]
    },
    {
