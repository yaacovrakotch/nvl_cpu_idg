    {
      "name": "RASTERLOOP_TYPE",
      "description": "PatConfig raster loop type: VMAXRASTERLOOP or VMINRASTERLOOP.",
      "values": ["VMAXRASTERLOOP", "VMINRASTERLOOP"],
      "replacements": [
        {"find": "VMAXRASTERLOOP", "replace": "\\RASTERLOOP_TYPE\\"},
