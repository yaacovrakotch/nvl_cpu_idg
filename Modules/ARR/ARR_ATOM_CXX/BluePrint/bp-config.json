        {"find": "SCREEN_ECCON_VMIN_F5", "replace": "SCREEN_ECCON_VMIN_\\ECC_FREQ\\"},
        {"find": "SCREEN_ECCON_VMIN_F6", "replace": "SCREEN_ECCON_VMIN_\\ECC_FREQ\\"},
        {"find": "SCREEN_ECCON_VMIN_F7", "replace": "SCREEN_ECCON_VMIN_\\ECC_FREQ\\"},
        {"find": "_VCCIA_F5_X_ECCSBFDV", "replace": "_VCCIA_\\ECC_FREQ\\_X_ECCSBFDV"},
        {"find": "_VCCIA_F6_X_ECCSBFDV", "replace": "_VCCIA_\\ECC_FREQ\\_X_ECCSBFDV"},
        {"find": "_VCCIA_F7_X_ECCSBFDV", "replace": "_VCCIA_\\ECC_FREQ\\_X_ECCSBFDV"},
        {"find": "per_array_f5.json", "replace": "per_array_\\ecc_freq\\.json"},
        {"find": "per_array_f6.json", "replace": "per_array_\\ecc_freq\\.json"},
        {"find": "per_array_f7.json", "replace": "per_array_\\ecc_freq\\.json"},
        {"find": "AT_F5_FREQ", "replace": "AT_\\ECC_FREQ\\_FREQ"},
        {"find": "AT_F6_FREQ", "replace": "AT_\\ECC_FREQ\\_FREQ"},
        {"find": "AT_F7_FREQ", "replace": "AT_\\ECC_FREQ\\_FREQ"}
      ]
    },
