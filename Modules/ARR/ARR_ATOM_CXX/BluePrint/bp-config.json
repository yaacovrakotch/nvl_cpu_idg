  "normalization": [
    {"pattern": "BypassPort\\s*=\\s*ARR_ATOM_CXX_Rules\\.TPRules\\([^)]+\\)", "replacement": "BypassPort = \\BYPASS_PORT_RULES\\"}
  ],

  "notes": [
    "CXX is a cross-socket module with no _CPU1 dual-die variants.",
    "F5 corner uses ATOM_TOP trial variable and Corners.AT_C5/FreqValues.AT_C5.",
    "F4XATLO/F5XATLO are low operating point variants of F4XAT/F5XAT.",
    "ECCON tests use ECC-on patterns with ECCSBFDV CtvTokensTC for fail data viewer.",
    "RETRY tests repeat ECCON with different ScreenTestSet (e.g. F5_TICK_UP).",
    "FMIN corner uses different timing TC and voltage forwarding from F1 results.",
    "LTTC tests use different patlist (lttc), LimitGuardband, StartVoltages (D.RFnAT).",
    "ECCON_FLOAT is a standalone FMIN ECCON test with BypassPort=1."
  ]
}
