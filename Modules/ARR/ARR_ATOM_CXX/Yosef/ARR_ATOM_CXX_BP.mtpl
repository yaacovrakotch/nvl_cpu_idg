        VoltageTargets = ARR_ATOM_CXX_Rules.TPRules(ARR_ATOM_CXX.voltarget_others,ARR_ATOM_CXX.voltarget_others,ARR_ATOM_CXX.voltarget_others,ARR_ATOM_CXX.voltarget_s16c,ARR_ATOM_CXX.voltarget_s16c,ARR_ATOM_CXX.voltarget_s16c,ARR_ATOM_CXX.voltarget_others,ARR_ATOM_CXX.voltarget_others);
        VminResult =__shared__::TpRule.If_48("ATOMM1_F5_VMIN_L2DATA,ATOMM0_F5_VMIN_L2DATA","ATOMM3_F5_VMIN_L2DATA,ATOMM2_F5_VMIN_L2DATA,ATOMM1_F5_VMIN_L2DATA,ATOMM0_F5_VMIN_L2DATA");
        TrialResult -2
        {
            PassFail Fail;
            TrialAction "Exit";
            Return -2;
        }
        TrialResult -1
        {
            PassFail Fail;
            TrialAction "Exit";
            Return -1;
        }
        TrialResult 0
        {
            PassFail Fail;
            TrialAction __shared__::TpRule.MTT_Rule("Next","Exit");
            Return 0;
        }
        TrialResult 1
        {
            PassFail Pass;
            TrialAction "Exit";
            Return 1;
        }
        TrialResult 2
        {
            PassFail Fail;
            TrialAction __shared__::TpRule.MTT_Rule("Next","Exit");
            Return 2;
        }
        TrialResult 3
        {
            PassFail Pass;
            TrialAction "Exit";
            Return 1;
        }
        TrialResult 4
        {
            PassFail Fail;
            TrialAction __shared__::TpRule.MTT_Rule("Next","Exit");
            Return 4;
        }
        TrialResult 5
        {
            PassFail Fail;
            TrialAction __shared__::TpRule.MTT_Rule("Next","Exit");
            Return 5;
        }
    }
}

