        PostInstance = "";
        BaseNumbers = "12545";
        BypassPort = -1;
        DtsConfiguration = ARR_ATOM_CXX.dts_Rules;
        #MultiPassMasks =__shared__::TpRule.If_48("","0011,1100");
        TrialParam CornerIdentifiers = __shared__::CornerIdentifiers.AT_C5;
        EndVoltageLimits = __shared__::FlowMatrixSingular.AT_HIGH_SEARCH_VALUE;
        ExecutionMode = "SearchWithScoreboard";
        FeatureSwitchSettings = "disable_masked_targets,fivr_mode_on,print_per_target_increments,print_scoreboard_counters";
        FivrCondition = "NOM";
        FlowIndex = __shared__::FlowMatrixSingular.FlowIndex;
        LimitGuardband = toString(__shared__::GBVars.LimitGuardband);
        ForwardingMode = "InputOutput";
