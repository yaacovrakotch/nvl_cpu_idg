{
    Patlist = "IPC::fun_cdie_vccr_sbft_fmax_fc_drg_hptp800_burstoff_list";
    LevelsTc = "CPU_IP_BASE::cpu_all_bf_x_x_ipc_lvl_min";
    TimingsTc = "FUN_CCF_CX48::cpu_fun_timing_mts800_tstprtclk400_tck100_fun_ccf_n2p";
    BypassPort = 1;
    DtsConfiguration = "";
    End = __shared__::FlowMatrixSingular.APEX_CCF_MIN;
    ExportTokens = "FXCCF";
    FivrCondition = "NOM_CCF_CORE";
    FivrConditionPlistParamName = "Patlist";
    ForwardingMode = "None";
    InitialMaskBits = "";
    PatternNameCounterIndexes = FUN_CCF_CX48_SPECS.PatNameIndex;
    PinMap = "";
    PreInstance = FUN_CCF_CX48_SPECS.UncoreConfigPreinstance;
    RecoveryOptions = "";
    RecoveryTracking = "";
    SetPointsPostInstance = PSPOST.CLR_FMAX+","+"CORE:nblctrl_core_l2:nblon";
    SetPointsPreInstance = PSPRE.CLR_FMAX+","+"MCdrv:"+FUN_CCF_CX48_SPECS.corefreq+":"+ __shared__::FlowMatrixSingular.CR_F3_FREQ+"GHz,MCdrv:"+FUN_CCF_CX48_SPECS.ringfreq+":"+ __shared__::FlowMatrixSingular.CCF_F5_FREQ+"GHz,CORE:nblctrl_core_l2:nbloff,MCdrv:R1_SET";
    Start = __shared__::FlowMatrixSingular.APEX_CCF_MAX;
    StepSize = 3;
    Targets = "CCF_FUNCCF";
    VoltageConverter = "--overrides CCF:"+__shared__::FlowMatrixSingular.CCF_VMAX_VALUE+", CORE1:"+FUN_CCF_CX48_SPECS.CR_VMAX_VALUE+",CORE0:"+FUN_CCF_CX48_SPECS.CR_VMAX_VALUE+" --railconfigurations CDIE_CCF_POWERMUX CDIE_CCF_NBLCTRL --dlvrpins VCCIA --expressions CCF_CORE";
}

