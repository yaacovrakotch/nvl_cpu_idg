    PrintFormat = "ShmooHub";
    SetPointsPlistParamName = "Patlist";
    SetPointsPreInstance = "MCdrv:atomfreq_0:"+__shared__::FlowMatrixSingular.AT_FMIN+"GHz,MCdrv:ringfreq_0:"+__shared__::FlowMatrixSingular.CCF_FMIN+"GHz,Fun_Atom_RAGN:ratio_modify:0.4GHz";
