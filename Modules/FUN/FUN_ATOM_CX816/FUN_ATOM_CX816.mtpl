    XAxisParam = "p_all_mts";
    XAxisParamType = "UserDefined";
    XAxisRange = "360e6:10e6:10";
    YAxisParam = "ATOM3,ATOM2,ATOM1,ATOM0";
    YAxisParamType = "UserDefined";
    YAxisRange = "0.8:-0.05:10";
    YAxisType = "FIVR";
}

