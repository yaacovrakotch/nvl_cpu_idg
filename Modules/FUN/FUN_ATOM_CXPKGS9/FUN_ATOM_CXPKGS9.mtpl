MultiTrialTest SBFT_ATOM_VMIN_K_F1XAT_X_AT_F1_X_AT_F1_FREQ_L2_DRAGON
{
    # SpeedFlow F1_F4 VminTC test with MTT
    TrialVariable CPU_TRIALS::FlowDomain.ATOM;
    TrialVariableExitAction "Continue";
    CSharpTrialTest VminTC "SBFT_ATOM_VMIN_K_F1XAT_X_AT_F1_" + __shared__::CustomFlowMatrixSpecs.AT_F1_FREQ_MHz + "_L2_DRAGON"
    {
        Patlist = "IPC::fun_cdie_atom_f1xat_l2_dragon_list_master";
        LevelsTc = "CPU_IP_BASE::cpu_all_bf_x_x_ipc_lvl_min";
        TimingsTc = "FUN_ATOM_CXPKGS9::cpu_fun_timing_mts800_tstprtclk400_tck100_funatom";
        BaseNumbers = "11501";
        BypassPort = -1;
        CornerIdentifiers = __shared__::CornerIdentifiers.AT_C1;
        DtsConfiguration = "";
        EndVoltageLimits = __shared__::FlowMatrixSingular.AT_LFM_VMIN_RAIN_KILL;
        ExecutionMode = "SearchWithScoreboard";
        FailCaptureCount = FUN_ATOM_CXPKGS9_Specs.Fail_Capture_Count;
        FeatureSwitchSettings = "disable_masked_targets,print_per_target_increments,print_scoreboard_counters,fivr_mode_on";
        FivrCondition = "NOM";
        FivrConditionPlistParamName = "Patlist";
        TrialParam FlowIndex = __shared__::FlowMatrix.FlowIndex;
        ForwardingMode = "InputOutput";
        LimitGuardband = toString(__shared__::GBVars.LimitGuardband);
        MaxFailsNum = toInteger(__shared__::Specs.CHK_MAX_FAILS);
        MaxRepetitionCount = 0;
        MultiPassMasks = "";
        PatternNameCounterIndexes = "9,10,11,12,13,14,15";
        PinMap = FUN_ATOM_CXPKGS9_Specs.recov_pinmap_l2_dragon_freq;
        PreInstance = "EvaluateExpression(--result G.U.S.FUNATOM_DYN_FREQ_BINARY --storagetype gsds --datatype string --expression Reverse(Dec2Bin(ToInt32(Ceiling(ToDouble([__shared__::FlowMatrixSingular.AT_F1_FREQ])*60)),10)))";
        RecoveryMode = "RecoveryPort";
        RecoveryOptions = __shared__::Recovery_Single.F1F4_recovery_opt_AT;
        RecoveryTrackingIncoming = FUN_ATOM_CXPKGS9_Specs.L2_Recovery_Tracking_In;
        RecoveryTrackingOutgoing = FUN_ATOM_CXPKGS9_Specs.L2_Recovery_Tracking_Out;
        ScoreboardEdgeTicks = toInteger(__shared__::Specs.CHK_EDGE_TICK);
        SetPointsPlistParamName = "Patlist";
        SetPointsPostInstance = PSPOST.AT_F1;
        TrialParam SetPointsPreInstance = PSPRE.AT_F1+",MCdrv:atomfreq_0:"+__shared__::FlowMatrix.AT_F1_FREQ+"GHz,MCdrv:ringfreq_0:"+__shared__::FlowMatrix.CCF_F1_FREQ+"GHz,Fun_Atom_RAGN:ratio_modify:0.8GHz,MCdrv:pwrmux_sel_atom_l2_0:vcclogic,MCdrv:pwrmux_sel_ccf_0:vcclogic,MCdrv:R1_SET";
        StartVoltages = __shared__::FlowMatrixSingular.AT_LOW_SEARCH_VALUE;
        StartVoltagesForRetry = __shared__::QNRTpRuleShared.If_PseudoVminForwarding(__shared__::QNRUsrvShared.StartVoltagesForRetry , "");
        StartVoltagesOffset = __shared__::QNRTpRuleShared.If_PseudoVminForwarding(__shared__::QNRUsrvShared.StartVoltagesOffset , "");
        StepSize = FUN_ATOM_CXPKGS9_Specs.StepSize;
        TestMode = "MultiVmin";
        VoltageConverter = FUN_ATOM_CXPKGS9_Specs.VoltageConverter_NBLRailAtom + DROPOUT.AT_F1;
        VoltageTargets = "ATOM31,ATOM21,ATOM11,ATOM01,ATOM3,ATOM2,ATOM1,ATOM0";
        TrialResult -2
        {
            PassFail Fail;
            TrialAction "Exit";
            Return -2;
        }
        TrialResult -1
        {
            PassFail Fail;
            TrialAction "Exit";
            Return -1;
        }
        TrialResult 0
        {
            PassFail Fail;
            TrialAction __shared__::TpRule.MTT_Rule("Next","Exit");
            Return 0;
        }
        TrialResult 1
        {
            PassFail Pass;
            TrialAction "Exit";
            Return 1;
        }
        TrialResult 2
        {
            PassFail Fail;
            TrialAction __shared__::TpRule.MTT_Rule("Next","Exit");
            Return 2;
        }
        TrialResult 3
        {
            PassFail Pass;
            TrialAction "Exit";
            Return 3;
        }
        TrialResult 4
        {
            PassFail Fail;
            TrialAction __shared__::TpRule.MTT_Rule("Next","Exit");
            Return 4;
        }
        TrialResult 5
        {
            PassFail Fail;
            TrialAction __shared__::TpRule.MTT_Rule("Next","Exit");
            Return 5;
        }
    }
}

