MultiTrialTest SBFT_CORE_\PURPOSE\_K_\MULTIFLOW\_X_CR_C\CORNER\_X_\CONTENT\
{
    TrialVariable CPU_TRIALS::FlowDomain.CORE_TOP;
    TrialVariableExitAction "Continue";
    CSharpTrialTest VminTC "SBFT_CORE_\PURPOSE\_K_\MULTIFLOW\_X_CR_" + __shared__::Corners.CR_C5+ "_" +__shared__::FreqInMHZ.CR_C5 + "_\CONTENT\"
    {
        Patlist = "IPC::fun_cdie_f\CORNER\xcr_\CONTENT\_hptp800_list_master";
        LevelsTc = "CPU_IP_BASE::cpu_all_bf_x_x_ipc_lvl_min";
        TimingsTc = FUN_CORE_\BOM\_Specs.Timing;
        BaseNumbers = "11101";
        BypassPort = -1;
        TrialParam CornerIdentifiers = __shared__::CornerIdentifiers.CR_C\CORNER\;
        DtsConfiguration = FUN_CORE_\BOM\_Specs.dtsconfig;
        EndVoltageLimits = __shared__::FlowMatrixSingular.CR_HIGH_SEARCH_VALUE;
        ExecutionMode = "SearchWithScoreboard";
        FailCaptureCount = FUN_CORE_\BOM\_Specs.FailCaptureCount;
        FeatureSwitchSettings = FUN_CORE_\BOM\_Specs.FeatureSwitchSettings;
        FivrCondition = "NOM_CCF_CORE";
        FivrConditionPlistParamName = "Patlist";
        FlowIndex = __shared__::FlowMatrixSingular.FlowIndex;
        ForwardingMode = "InputOutput";
        LimitGuardband = toString(__shared__::GBVars.LimitGuardband);
        MaxFailsNum = toInteger(__shared__::Specs.CHK_MAX_FAILS);
        MultiPassMasks = FUN_CORE_\BOM\_Specs.MultiPass_2CDIE;
        PatternNameCounterIndexes = FUN_CORE_\BOM\_Specs.PatNameIndex;
        PinMap = FUN_CORE_\BOM\_Specs.PinMap_FREQ_NONMISR;
        TrialParam PreInstance = "EvaluateExpression(--result G.U.S.FUNCORE_DYN_FREQ_BINARY --storagetype gsds --datatype string --expression Reverse(Dec2Bin(ToInt32(Ceiling(ToDouble("+__shared__::FreqValues.CR_C5+")*60)),9)))";
        RecoveryMode = FUN_CORE_\BOM\_Specs.CORE_RecoveryMode_MTT;
        TrialParam RecoveryOptions = __shared__::Recovery.MTT_recovery_opt_CR;
        RecoveryTrackingIncoming = __shared__::RecoveryTracker.INCOMING_CR;
        RecoveryTrackingOutgoing = __shared__::RecoveryTracker.OUTGOING_CR;
        ScoreboardEdgeTicks = toInteger(__shared__::Specs.CHK_EDGE_TICK);
        SetPointsPlistParamName = "Patlist";
        SetPointsPostInstance = PSPOST.CR_F\CORNER\;
        TrialParam SetPointsPreInstance = PSPRE.CR_F\CORNER\+","+"MCdrv:"+FUN_CORE_\BOM\_Specs.corefreq+":"+ __shared__::FreqValues.CR_C\CORNER\+"GHz,MCdrv:"+FUN_CORE_\BOM\_Specs.ringfreq+":"+ __shared__::FreqValues.CCF_C\CORNER\+"GHz";
        StartVoltages = __shared__::FlowMatrixSingular.CR_LOW_SEARCH_VALUE;
        TrialParam StartVoltagesForRetry = __shared__::QNRTpRuleShared.If_PseudoVminForwarding(__shared__::QNRUsrvShared.StartVoltagesForRetryF5 , ["","",""]);
        TrialParam StartVoltagesOffset = __shared__::QNRTpRuleShared.If_PseudoVminForwarding(__shared__::QNRUsrvShared.StartVoltagesOffsetF5 , ["","",""]);
        StepSize = toDouble(__shared__::FlowMatrixSingular.CR_SEARCH_RESOLUTION);
        TestMode = "MultiVmin";
        VoltageConverter = FUN_CORE_\BOM\_Specs.VoltageConverter_NBLRail + DROPOUT.CR_F\CORNER\;
        VoltageTargets = FUN_CORE_\BOM\_Specs.VoltageTarget2C;
        TrialResult -2
        {
            PassFail Fail;
            TrialAction Exit;
            Return -2;
        }
        TrialResult -1
        {
            PassFail Fail;
            TrialAction Exit;
            Return -1;
        }
        TrialResult 0
        {
            PassFail Fail;
            TrialAction __shared__::TpRule.MTT_Rule("Next","Exit");
            Return 0;
        }
        TrialResult 1
        {
            PassFail Pass;
            TrialAction Exit;
            Return 1;
        }
        TrialResult 2
        {
            PassFail Fail;
            TrialAction __shared__::TpRule.MTT_Rule("Next","Exit");
            Return 0;
        }
        TrialResult 3
        {
            PassFail Fail;
            TrialAction __shared__::TpRule.MTT_Rule("Next","Exit");
            Return 0;
        }
        TrialResult 4
        {
            PassFail Fail;
            TrialAction __shared__::TpRule.MTT_Rule("Next","Exit");
            Return 0;
        }
        TrialResult 5
        {
            PassFail Fail;
            TrialAction __shared__::TpRule.MTT_Rule("Next","Exit");
            Return 0;
        }
    }
}

