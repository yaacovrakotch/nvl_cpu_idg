MultiTrialTest SBFT_CORE_VMAX_K_VMAXXCR_X_CR_\VMAX_SINGLE\_X_\CONTENT\
{
    TrialVariable CPU_TRIALS::FlowDomain.CORE;
    TrialVariableExitAction "Restore";
    CSharpTrialTest VminTC "SBFT_CORE_VMAX_K_VMAXXCR_X_CR_\VMAX_SINGLE\_" + __shared__::CustomFlowMatrixSpecs.CR_\VMAX_SINGLE\_FREQ_MHz + "_\CONTENT\"
    {
        Patlist = "IPC::fun_cdie_VMAXXCR_\VMAX_SINGLE\_\CONTENT\_hptp800_list_master";
        LevelsTc = "CPU_IP_BASE::cpu_all_bf_x_x_ipc_lvl_max";
        TimingsTc = FUN_CORE_\BOM\_Specs.Timing;
        BaseNumbers = "11151";
        BypassPort = -1;
        DtsConfiguration = FUN_CORE_\BOM\_Specs.dtsconfig;
        EndVoltageLimits = __shared__::FlowMatrixSingular.CR_VMAX_VALUE;
        ExecutionMode = "SearchWithScoreboard";
        FailCaptureCount = FUN_CORE_\BOM\_Specs.FailCaptureCount;
        FeatureSwitchSettings = FUN_CORE_\BOM\_Specs.FeatureSwitchSettings;
        FivrCondition = "NOM_CCF_CORE";
        FivrConditionPlistParamName = "Patlist";
        TrialParam FlowIndex = __shared__::FlowMatrix.FlowIndex;
        ForwardingMode = "Input";
        MaxFailsNum = toInteger(__shared__::Specs.VMX_MAX_FAILS);
	    MultiPassMasks = "";
        PatternNameCounterIndexes = FUN_CORE_\BOM\_Specs.PatNameIndex;
        PinMap = FUN_CORE_\BOM\_Specs.PinMap_FREQ_NONMISR;
        PreInstance = "EvaluateExpression(--result G.U.S.FUNCORE_DYN_FREQ_BINARY --storagetype gsds --datatype string --expression Reverse(Dec2Bin(ToInt32(Ceiling(ToDouble("+__shared__::FlowMatrixSingular.CR_F1_FREQ+")*60)),9)))";
        RecoveryMode = "NoRecovery";
        RecoveryOptions = "";
        RecoveryTrackingIncoming = __shared__::RecoveryTracker.INCOMING_CR;
        RecoveryTrackingOutgoing = "";
        ScoreboardEdgeTicks = toInteger(__shared__::Specs.VMX_EDGE_TICK);
        SetPointsPlistParamName = "Patlist";
        SetPointsPostInstance = PSPOST.CR_F1+",CORE:nblctrl_core_l2:nblon,CORE:nblctrl1_core_l2:nblon";
        SetPointsPreInstance = PSPRE.CR_F1+","+"MCdrv:"+FUN_CORE_\BOM\_Specs.corefreq+":"+ __shared__::FlowMatrixSingular.CR_F1_FREQ+"GHz,MCdrv:"+FUN_CORE_\BOM\_Specs.ringfreq+":"+ __shared__::FlowMatrixSingular.CCF_F1_FREQ+"GHz,CORE:nblctrl_core_l2:nbloff,CORE:nblctrl1_core_l2:nbloff";
        StartVoltages = __shared__::FlowMatrixSingular.CR_VMAX_VALUE;
        StepSize = toDouble(__shared__::FlowMatrixSingular.CR_SEARCH_RESOLUTION);
        TestMode = "Scoreboard";
        VoltageConverter = FUN_CORE_\BOM\_Specs.VoltageConverterVMAX + FUN_CORE_\BOM\_Specs.VoltageConverterVMAX\CONTENT\ +" --dlvrpins VCCIA --expressions " + DROPOUT.CR_F1;
        VoltageTargets = FUN_CORE_\BOM\_Specs.VoltageTarget2C;
        TrialResult -2
        {
            PassFail Fail;
            TrialAction Exit;
            Return -2;
        }
        TrialResult -1
        {
            PassFail Fail;
            TrialAction Exit;
            Return -1;
        }
        TrialResult 0
        {
            PassFail Fail;
            TrialAction Exit;
            Return 0;
        }
        TrialResult 1
        {
            PassFail Pass;
            TrialAction Exit;
            Return 1;
        }
        TrialResult 2
        {
            PassFail Fail;
            TrialAction Exit;
            Return 0;
        }
        TrialResult 3
        {
            PassFail Fail;
            TrialAction Exit;
            Return 0;
        }
        TrialResult 4
        {
            PassFail Fail;
            TrialAction Exit;
            Return 0;
        }
        TrialResult 5
        {
            PassFail Fail;
            TrialAction Exit;
            Return 0;
        }
    }
}

