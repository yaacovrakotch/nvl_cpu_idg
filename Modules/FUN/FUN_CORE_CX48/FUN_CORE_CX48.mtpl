MultiTrialTest SBFT_CORE_VMIN_K_LTTCCPU_X_CR_F5_X_FREQ_X_MLC_DRG_ALL
{
    # SpeedFlow F5_F7 VminTC test with MTT
    TrialVariable CPU_TRIALS::FlowDomain.CORE_TOP;
    TrialVariableExitAction "Restore";
    CSharpTrialTest VminTC "SBFT_CORE_VMIN_K_LTTCCPU_X_CR_" + __shared__::Corners.CR_C5+ "_" +__shared__::FreqInMHZ.CR_C5 + "_MLC_DRG_ALL"
    {
        Patlist = "IPC::fun_cdie_lttccpu_mlc_drg_hptp800_list";
        LevelsTc = "CPU_IP_BASE::cpu_all_bf_x_x_ipc_lvl_min";
        TimingsTc = "FUN_CORE_CX48::cpu_fun_timing_mts800_tstprtclk400_tck100_fun_core_n2p";
        BaseNumbers = "11171";
        BypassPort = 1;
        CornerIdentifiers = "";
        DtsConfiguration = FUN_CORE_CX48_Specs.dtsconfig_cx48;
        TrialParam EndVoltageLimits = "D.R"+__shared__::Corners.CR_C5+"CR";
        ExecutionMode = "SearchWithScoreboard";
        FailCaptureCount = FUN_CORE_CX48_Specs.FailCaptureCount;
        FeatureSwitchSettings = FUN_CORE_CX48_Specs.FeatureSwitchSettings;
        FivrCondition = "NOM_CCF_CORE";
        FivrConditionPlistParamName = "Patlist";
        FlowIndex = __shared__::FlowMatrixSingular.FlowIndex;
        ForwardingMode = "Input";
        LimitGuardband = "31mV";
        MaxFailsNum = toInteger(__shared__::Specs.CHK_MAX_FAILS);
        PatternNameCounterIndexes = FUN_CORE_CX48_Specs.PatNameIndex;
        PinMap = FUN_CORE_CX48_Specs.PinMap_FREQ_NONMISR;
        RecoveryMode = "NoRecovery";
        RecoveryTrackingIncoming = __shared__::RecoveryTracker.INCOMING_CR;
        ScoreboardEdgeTicks = toInteger(__shared__::Specs.CHK_EDGE_TICK);
        SetPointsPlistParamName = "Patlist";
        SetPointsPostInstance = PSPOST.CR_F5;
        TrialParam SetPointsPreInstance = PSPRE.CR_F5+","+"MCdrv:"+FUN_CORE_CX48_Specs.corefreq+":"+ __shared__::FreqValues.CR_C5+"GHz,MCdrv:"+FUN_CORE_CX48_Specs.ringfreq+":0.8GHz,MCfun:DBGCNTR:"+ __shared__::Corners.CR_C5+",MCfun:ratio_modify:"+FUN_CORE_CX48_Specs.MLC_DRG_C5;
        TrialParam StartVoltages = "D.R"+__shared__::Corners.CR_C5+"CR";
        TrialParam StartVoltagesForRetry = __shared__::QNRTpRuleShared.If_PseudoVminForwarding(__shared__::QNRUsrvShared.StartVoltagesForRetryF5 , ["","",""]);
        TrialParam StartVoltagesOffset = __shared__::QNRTpRuleShared.If_PseudoVminForwarding(__shared__::QNRUsrvShared.StartVoltagesOffsetF5 , ["","",""]);
        StepSize = toDouble(__shared__::FlowMatrixSingular.CR_SEARCH_RESOLUTION);
        TestMode = "MultiVmin";
        VoltageConverter = FUN_CORE_CX48_Specs.VoltageConverter_NBLRail + DROPOUT.CR_F5;
        VoltageTargets = FUN_CORE_CX48_Specs.VoltageTarget1C;
        TrialResult -2
        {
            PassFail Fail;
            TrialAction "Exit";
            Return -2;
        }
        TrialResult -1
        {
            PassFail Fail;
            TrialAction "Exit";
            Return -1;
        }
        TrialResult 0
        {
            PassFail Fail;
            TrialAction "Exit";
            Return 0;
        }
        TrialResult 1
        {
            PassFail Pass;
            TrialAction "Exit";
            Return 1;
        }
        TrialResult 2
        {
            PassFail Fail;
            TrialAction "Exit";
            Return 0;
        }
        TrialResult 3
        {
            PassFail Fail;
            TrialAction "Exit";
            Return 0;
        }
        TrialResult 4
        {
            PassFail Fail;
            TrialAction "Exit";
            Return 0;
        }
        TrialResult 5
        {
            PassFail Fail;
            TrialAction "Exit";
            Return 0;
        }
    }
}

