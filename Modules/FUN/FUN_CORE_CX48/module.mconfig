<?xml version="1.0" encoding="utf-8" ?>
<ModuleConfiguration>
	<Patterns>
		<!--The PORRoot section is used to declare production plists used by the module.
				PORRoot can be declared per BomGroup or decorated with the IP name if, in Itradut TP,  IP plists are used by package module.
				<PORRoot IP="" BomGroup="" Path="" Rev="" Patch="">-->
		<PORRoot BomGroup="CLASS_NVL_S16C" Path="I:\hdmxpats\nvl_cpu\MCfun\" Rev="RevTCN48T0.9" Patch="p1">
			<PlistFiles>
				<PlistFile>iafunc_core_hptp800_allplist.plist</PlistFile>
			</PlistFiles>
		</PORRoot>

		<PORRoot BomGroup="CLASS_NVL_H16C" Path="I:\hdmxpats\nvl_cpu\MCfun\" Rev="RevTCN48T0.9" Patch="p1">
			<PlistFiles>
				<PlistFile>iafunc_core_hptp800_allplist.plist</PlistFile>
			</PlistFiles>
		</PORRoot>

		<PORRoot BomGroup="CLASS_NVL_P16C" Path="I:\hdmxpats\nvl_cpu\MCfun\" Rev="RevTCN48T0.9" Patch="p1">
			<PlistFiles>
				<PlistFile>iafunc_core_hptp800_allplist.plist</PlistFile>
			</PlistFiles>
		</PORRoot>

		<!--The ENGRoot section is used to declare engineering plists used by the module.
			  IP attribute can be used for ENGRoot: <ENGRoot IP="" Path="">-->
		<!--<ENGRoot Path="" >
			<PlistFiles>
			  <PlistFile> </PlistFile>
			  <PlistFile BomGroup=""> </PlistFile>
			</PlistFiles>
		  </ENGRoot>-->

	</Patterns>

