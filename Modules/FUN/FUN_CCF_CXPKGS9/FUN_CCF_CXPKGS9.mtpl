MultiTrialTest SBFT_CCF_VMIN_K_FMINXCCF_X_CCF_FMIN_X_FC_DRG
{
    # Sample VminTC test with MTT
    TrialVariable CPU_TRIALS::FlowDomain.RING;
    TrialVariableExitAction "Restore";
    CSharpTrialTest VminTC "SBFT_CCF_VMIN_K_FMINXCCF_X_CCF_FMIN_" + __shared__::CustomFlowMatrixSpecs.CCF_FMIN_MHz + "_FC_DRG"
    {
        Patlist = "IPC::fun_cdie_vccr_sbft_fmin_fc_drg_hptp800_burstoff_list_master";
        LevelsTc = "CPU_IP_BASE::cpu_all_bf_x_x_ipc_lvl_min";
        TimingsTc = "FUN_CCF_CXPKGS9::cpu_fun_timing_mts400_tstprtclk200_tck50_i_drv_mul_fmin_fun_CCF";
        BaseNumbers = "11412";
        BypassPort = -1;
        CornerIdentifiers = "CCF1@F1,CCF0@F1";
        DtsConfiguration = "FUN_CCF_CDIE_S52C";
        EndVoltageLimits = __shared__::FlowMatrixSingular.CR_LFM_VMIN_RAIN_KILL;
        ExecutionMode = "SearchWithScoreboard";
        FailCaptureCount = FUN_CCF_CXPKGS9_SPECS.Fail_Capture_Count;
        FeatureSwitchSettings = "fivr_mode_on, disable_masked_targets,print_per_target_increments,print_scoreboard_counters";
        FivrCondition = "NOM_CCF_CORE";
        FivrConditionPlistParamName = "Patlist";
        TrialParam FlowIndex = __shared__::FlowMatrix.FlowIndex;
        ForwardingMode = "Input";
        LimitGuardband = toString(__shared__::GBVars.FminLimitGuardband);
        MaxFailsNum = toInteger(__shared__::Specs.CHK_MAX_FAILS);
        PatternNameCounterIndexes = FUN_CCF_CXPKGS9_SPECS.PatNameIndex;
        PinMap = FUN_CCF_CXPKGS9_SPECS.FC_Pin_Map;
        PreInstance = FUN_CCF_CXPKGS9_SPECS.UncoreConfigPreinstance;
        RecoveryMode = "NoRecovery";
        RecoveryOptions = FUN_CCF_CXPKGS9_SPECS.FC_Recovery_Options;
        RecoveryTrackingIncoming = FUN_CCF_CXPKGS9_SPECS.FC_Recovery_Tracking;
        RecoveryTrackingOutgoing = FUN_CCF_CXPKGS9_SPECS.FC_Recovery_Tracking;
        ScoreboardEdgeTicks = toInteger(__shared__::Specs.CHK_EDGE_TICK);
        SetPointsPlistParamName = "Patlist";
        SetPointsPostInstance = PSPOST.CLR_FMIN+","+"CORE:nblctrl_core_l2:nblon,"+FUN_CCF_CXPKGS9_SPECS.MCfunCCF_FMIN_DRVMASK;
        SetPointsPreInstance = PSPRE.CLR_FMIN+","+"MCdrv:"+FUN_CCF_CXPKGS9_SPECS.corefreq+":"+ __shared__::FlowMatrixSingular.CR_FMIN+"GHz,MCdrv:"+FUN_CCF_CXPKGS9_SPECS.ringfreq+":"+ __shared__::FlowMatrixSingular.CCF_FMIN+"GHz,CORE:nblctrl_core_l2:nbloff,MCdrv:R1_SET,"+FUN_CCF_CXPKGS9_SPECS.MCfunCCF_FMIN_DRVMASK;
        StartVoltages = __shared__::FlowMatrixSingular.CR_LOW_SEARCH_VALUE;
        StartVoltagesForRetry = __shared__::QNRTpRuleShared.If_PseudoVminForwarding(__shared__::QNRUsrvShared.StartVoltagesForRetry , "");
        StartVoltagesOffset = __shared__::QNRTpRuleShared.If_PseudoVminForwarding(__shared__::QNRUsrvShared.StartVoltagesOffset , "");
        StepSize = toDouble(__shared__::FlowMatrixSingular.CR_SEARCH_RESOLUTION);
        TestMode = "MultiVmin";
        VoltageConverter = "--overrides CORE31:"+__shared__::FlowMatrixSingular.CR_VMAX_VALUE+",CORE3:"+__shared__::FlowMatrixSingular.CR_VMAX_VALUE+",CORE2:"+__shared__::FlowMatrixSingular.CR_VMAX_VALUE+",CORE21:"+__shared__::FlowMatrixSingular.CR_VMAX_VALUE+",CORE11:"+__shared__::FlowMatrixSingular.CR_VMAX_VALUE+",CORE1:"+__shared__::FlowMatrixSingular.CR_VMAX_VALUE+",CORE01:"+__shared__::FlowMatrixSingular.CR_VMAX_VALUE+",CORE0:"+__shared__::FlowMatrixSingular.CR_VMAX_VALUE+"  --dlvrpins VCCIA --expressions CCF_CORE";
        VoltageTargets = FUN_CCF_CXPKGS9_SPECS.VoltageTarget2Cdie;
        TrialResult -2
        {
            PassFail Fail;
            TrialAction "Exit";
            Return -2;
        }
        TrialResult -1
        {
            PassFail Fail;
            TrialAction "Exit";
            Return -1;
        }
        TrialResult 0
        {
            PassFail Fail;
            TrialAction "Next";
            Return 0;
        }
        TrialResult 1
        {
            PassFail Pass;
            TrialAction "Exit";
            Return 1;
        }
        TrialResult 2
        {
            PassFail Fail;
            TrialAction "Next";
            Return 0;
        }
        TrialResult 3
        {
            PassFail Fail;
            TrialAction "Next";
            Return 0;
        }
        TrialResult 4
        {
            PassFail Fail;
            TrialAction "Next";
            Return 0;
        }
        TrialResult 5
        {
            PassFail Fail;
            TrialAction "Next";
            Return 0;
        }
    }
}

