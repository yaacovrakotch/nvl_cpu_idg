MultiTrialTest SBFT_CORE_VMIN_K_FMINXCR_X_CR_FMIN_X_MLC
{
    # FMIN VminTC test with MTT
    TrialVariable CPU_TRIALS::FlowDomain.CORE;
    TrialVariableExitAction "Continue";
    CSharpTrialTest VminTC "SBFT_CORE_VMIN_K_FMINXCR_X_CR_FMIN_" + __shared__::CustomFlowMatrixSpecs.CR_FMIN_MHz + "_MLC"
    {
        Patlist = "IPC::fun_cdie_fminxcr_mlc_hptp800_list";
        LevelsTc = "CPU_IP_BASE::cpu_all_bf_x_x_ipc_lvl_min";
        TimingsTc = "FUN_CORE_CX816::cpu_fun_timing_mts400_tstprtclk200_tck50_i_drv_mul_fun_CORE";
        BaseNumbers = "11136";
        BypassPort = __shared__::TpRule.If_DS0_DS1_M(-1, 1, -1, 1);
        CornerIdentifiers = "CR3@F1,CR2@F1,CR1@F1,CR0@F1";
        DtsConfiguration = __shared__::TpRule.If_DS0_DS1_M(FUN_CORE_CX816_Specs.dtsconfig_s28cn2p, FUN_CORE_CX816_Specs.dtsconfig_s52c, FUN_CORE_CX816_Specs.dtsconfig_hx28c, FUN_CORE_CX816_Specs.dtsconfig_hx28c);
        EndVoltageLimits = __shared__::FlowMatrixSingular.CR_LFM_VMIN_RAIN_KILL;
        ExecutionMode = "SearchWithScoreboard";
        FailCaptureCount = FUN_CORE_CX816_Specs.FailCaptureCount;
        FeatureSwitchSettings = FUN_CORE_CX816_Specs.FeatureSwitchSettings;
        FivrCondition = "NOM_CCF_CORE";
        FivrConditionPlistParamName = "Patlist";
        TrialParam FlowIndex = __shared__::FlowMatrix.FlowIndex;
        ForwardingMode = "Input";
        LimitGuardband = toString(__shared__::GBVars.FminLimitGuardband);
        MaxFailsNum = toInteger(__shared__::Specs.CHK_MAX_FAILS);
        PatternNameCounterIndexes = FUN_CORE_CX816_Specs.PatNameIndex;
        PinMap = FUN_CORE_CX816_Specs.PinMap_FREQ_NONMISR;
        RecoveryMode = FUN_CORE_CX816_Specs.CORE_RecoveryMode_NoRec;
        RecoveryTrackingIncoming = FUN_CORE_CX816_Specs.CDIE0_Recovery_Tracking;
        ScoreboardEdgeTicks = toInteger(__shared__::Specs.CHK_EDGE_TICK);
        SetPointsPlistParamName = "Patlist";
        SetPointsPostInstance = PSPOST.CR_FMIN+","+FUN_CORE_CX816_Specs.MCfun_FMIN_UNMASK_CR;
        SetPointsPreInstance = PSPRE.CR_FMIN+","+"MCdrv:"+FUN_CORE_CX816_Specs.corefreq+":"+ __shared__::FlowMatrixSingular.CR_FMIN+"GHz,MCdrv:"+FUN_CORE_CX816_Specs.ringfreq+":"+ __shared__::FlowMatrixSingular.CCF_FMIN+"GHz,MCfun:ratio_modify:"+FUN_CORE_CX816_Specs.MLC_FMIN+",MCfun:DBGCNTR:FMIN,"+FUN_CORE_CX816_Specs.MCfun_FMIN_MASK_CR;
        StartVoltages = __shared__::FlowMatrixSingular.CR_LOW_SEARCH_VALUE;
        StartVoltagesForRetry = __shared__::QNRTpRuleShared.If_PseudoVminForwarding(__shared__::QNRUsrvShared.StartVoltagesForRetry , "");
        StartVoltagesOffset = __shared__::QNRTpRuleShared.If_PseudoVminForwarding(__shared__::QNRUsrvShared.StartVoltagesOffset , "");
        StepSize = toDouble(__shared__::FlowMatrixSingular.CR_SEARCH_RESOLUTION);
        TestMode = "MultiVmin";
        VminResult = "SBFT_MLC_CR3_FMIN_FF_SEARCH,SBFT_MLC_CR2_FMIN_FF_SEARCH,SBFT_MLC_CR1_FMIN_FF_SEARCH,SBFT_MLC_CR0_FMIN_FF_SEARCH";
        VoltageConverter = FUN_CORE_CX816_Specs.VoltageConverter_NBLRail + DROPOUT.CR_FMIN;
        VoltageTargets = FUN_CORE_CX816_Specs.VoltageTarget1C;
        TrialResult -2
        {
            PassFail Fail;
            TrialAction "Exit";
            Return -2;
        }
        TrialResult -1
        {
            PassFail Fail;
            TrialAction "Exit";
            Return -1;
        }
        TrialResult 0
        {
            PassFail Fail;
            TrialAction __shared__::TpRule.MTT_Rule("Next","Exit");
            Return 0;
        }
        TrialResult 1
        {
            PassFail Pass;
            TrialAction "Exit";
            Return 1;
        }
        TrialResult 2
        {
            PassFail Fail;
            TrialAction __shared__::TpRule.MTT_Rule("Next","Exit");
            Return 0;
        }
        TrialResult 3
        {
            PassFail Fail;
            TrialAction __shared__::TpRule.MTT_Rule("Next","Exit");
            Return 0;
        }
        TrialResult 4
        {
            PassFail Fail;
            TrialAction __shared__::TpRule.MTT_Rule("Next","Exit");
            Return 0;
        }
        TrialResult 5
        {
            PassFail Fail;
            TrialAction __shared__::TpRule.MTT_Rule("Next","Exit");
            Return 0;
        }
    }
}

