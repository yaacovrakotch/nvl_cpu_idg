CSharpTest ApexTC SBFT_CORE_VMIN_E_F5XCR_X_CR_F5_1100_MLC_APEX_FMAX
{
    Patlist = "IPC::fun_cdie_f5xcr_fmax_mlc_hptp800_list";
    LevelsTc = "CPU_IP_BASE::cpu_all_bf_x_x_ipc_lvl_min";
    TimingsTc = "FUN_CORE_CX816::cpu_fun_timing_mts800_tstprtclk400_tck100_fun_core_n2p";
    BypassPort = __shared__::TpRule.If_DS0_DS1_M(1, -1, BYPASS_PARAMETER.APEXTC_BYPASS, 1);
    DtsConfiguration = __shared__::TpRule.If_DS0_DS1_M(FUN_CORE_CX816_Specs.dtsconfig_s28cn2p, FUN_CORE_CX816_Specs.dtsconfig_s52c, FUN_CORE_CX816_Specs.dtsconfig_hx28c, FUN_CORE_CX816_Specs.dtsconfig_hx28c);
    End = __shared__::FlowMatrixSingular.APEX_CORE_MIN;
    ExportTokens = __shared__::APEX_Tokens.CRToken;
    FailCaptureCount = FUN_CORE_CX816_Specs.FailCaptureCount_Stagger;
    FivrCondition = "NOM_CCF_CORE";
    FivrConditionPlistParamName = "Patlist";
    ForwardingMode = "Input";
    InitialMaskBits = "1100";
    PatternNameCounterIndexes = FUN_CORE_CX816_Specs.PatNameIndex;
    PinMap = FUN_CORE_CX816_Specs.PinMap_FREQ_NONMISR;
    RecoveryOptions = "";
    RecoveryTracking = "CR";
    SetPointsPostInstance = PSPOST.CR_F5+",CORE:nblctrl_core_l2:nblon";
    SetPointsPreInstance = PSPRE.CR_F5+","+"MCdrv:"+FUN_CORE_CX816_Specs.corefreq+":"+ __shared__::FlowMatrixSingular.CR_F5_FREQ+"GHz,MCdrv:"+FUN_CORE_CX816_Specs.ringfreq+":"+ __shared__::FlowMatrixSingular.CCF_F1_FREQ+"GHz,CORE:nblctrl_core_l2:nbloff,MCfun:DBGCNTR:FMAX,MCfun:ratio_modify:"+FUN_CORE_CX816_Specs.MLC_FMAX;
    Start = __shared__::FlowMatrixSingular.APEX_CORE_MAX;
    StepSize = 1;
    Targets = "FCORE3,FCORE2,FCORE1,FCORE0";
    VoltageConverter = "--overrides CORE1:"+__shared__::FlowMatrixSingular.CR_VMAX_VALUE+",CORE0:"+__shared__::FlowMatrixSingular.CR_VMAX_VALUE+ " --dlvrpins VCCIA --expressions " + DROPOUT.CR_F5;
}

