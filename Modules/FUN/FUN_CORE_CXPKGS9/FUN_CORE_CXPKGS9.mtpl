        SetPointsPreInstance = PSPRE.CR_FMIN+","+"MCdrv:"+FUN_CORE_CXPKGS9_Specs.corefreq+":"+ __shared__::FlowMatrixSingular.CR_FMIN+"GHz,MCdrv:"+FUN_CORE_CXPKGS9_Specs.ringfreq+":"+ __shared__::FlowMatrixSingular.CCF_FMIN+"GHz,"+FUN_CORE_CXPKGS9_Specs.MCfun_FMIN_MASK_CR;
