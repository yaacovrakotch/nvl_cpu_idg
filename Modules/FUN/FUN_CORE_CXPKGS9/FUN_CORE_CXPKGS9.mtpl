        PreInstance = "EvaluateExpression(--result G.U.S.FUNCORE_DYN_FREQ_BINARY --storagetype gsds --datatype string --expression Reverse(Dec2Bin(ToInt32(Ceiling(ToDouble("+__shared__::FlowMatrixSingular.CR_FMIN+")*60)),9)))";
        RecoveryMode = FUN_CORE_CXPKGS9_Specs.CORE_RecoveryMode_NoRec;
        RecoveryTrackingIncoming = FUN_CORE_CXPKGS9_Specs.CDIE1_CDIE0_Recovery_Tracking;
        ScoreboardEdgeTicks = toInteger(__shared__::Specs.CHK_EDGE_TICK);
        SetPointsPlistParamName = "Patlist";
