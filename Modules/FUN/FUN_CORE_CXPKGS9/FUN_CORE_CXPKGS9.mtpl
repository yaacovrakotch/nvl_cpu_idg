MultiTrialTest SBFT_CORE_VMIN_K_F5XCR_X_CR_F5_X_FREQ_X_MLC
{
    # SpeedFlow F5_F7 VminTC test with MTT
    TrialVariable CPU_TRIALS::FlowDomain.CORE_TOP;
    TrialVariableExitAction "Continue";
    CSharpTrialTest VminTC "SBFT_CORE_VMIN_K_F5XCR_X_CR_" + __shared__::Corners.CR_C5+ "_" +__shared__::FreqInMHZ.CR_C5 + "_MLC"
    {
        Patlist = "IPC::fun_cdie_f5xcr_mlc_hptp800_list_master";
        LevelsTc = "CPU_IP_BASE::cpu_all_bf_x_x_ipc_lvl_min";
        TimingsTc = "FUN_CORE_CXPKGS9::cpu_fun_timing_mts800_tstprtclk400_tck100_fun_core";
        BaseNumbers = "11101";
        BypassPort = -1;
        TrialParam CornerIdentifiers = __shared__::CornerIdentifiers.CR_C5;
        DtsConfiguration = FUN_CORE_CXPKGS9_Specs.dtsconfig_ctv;
        EndVoltageLimits = __shared__::FlowMatrixSingular.CR_HIGH_SEARCH_VALUE;
        ExecutionMode = "SearchWithScoreboard";
        FailCaptureCount = FUN_CORE_CXPKGS9_Specs.FailCaptureCount;
        FeatureSwitchSettings = FUN_CORE_CXPKGS9_Specs.FeatureSwitchSettings;
        FivrCondition = "NOM_CCF_CORE";
        FivrConditionPlistParamName = "Patlist";
        FlowIndex = __shared__::FlowMatrixSingular.FlowIndex;
