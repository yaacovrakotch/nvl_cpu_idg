        BaseNumbers = "11136";
        BypassPort = -1;
        CornerIdentifiers = "CR7@F1,CR6@F1,CR5@F1,CR4@F1,CR3@F1,CR2@F1,CR1@F1,CR0@F1";
        EndVoltageLimits = __shared__::FlowMatrixSingular.CR_LFM_VMIN_RAIN_KILL;
