        SetPointsPostInstance = PSPOST.CR_F4+",CCF:nblctrl_ccf:ccfnblon,CCF:nblctrl1_ccf:ccfnblon";
        SetPointsPreInstance = PSPRE.CR_F4+","+"MCdrv:"+FUN_CORE_CXPKGS9_Specs.corefreq+":"+ __shared__::FlowMatrixSingular.CR_F4_FREQ+"GHz,MCdrv:"+FUN_CORE_CXPKGS9_Specs.ringfreq+":"+ __shared__::FlowMatrixSingular.CCF_F4_FREQ+"GHz,CCF:nblctrl_ccf:ccfnbloff,CCF:nblctrl1_ccf:ccfnbloff";
        StartVoltages = __shared__::FlowMatrixSingular.CR_LOW_SEARCH_VALUE;
        StartVoltagesForRetry = __shared__::QNRTpRuleShared.If_PseudoVminForwarding(__shared__::QNRUsrvShared.StartVoltagesForRetryF4 , "");
        StartVoltagesOffset = __shared__::QNRTpRuleShared.If_PseudoVminForwarding(__shared__::QNRUsrvShared.StartVoltagesOffsetF4 , "");
        StepSize = toDouble(__shared__::FlowMatrixSingular.CR_SEARCH_RESOLUTION);
        TestMode = "MultiVmin";
        VoltageConverter = "--overrides CCF1:"+__shared__::FlowMatrixSingular.CCF_VMAX_VALUE+",CCF:"+__shared__::FlowMatrixSingular.CCF_VMAX_VALUE + FUN_CORE_CXPKGS9_Specs.VoltageConverter_NBLRailCCFS52C + DROPOUT.CR_F4;
        VoltageTargets = FUN_CORE_CXPKGS9_Specs.VoltageTarget2C;
        TrialResult -2
        {
            PassFail Fail;
            TrialAction "Exit";
            Return -2;
        }
        TrialResult -1
        {
            PassFail Fail;
            TrialAction "Exit";
            Return -1;
        }
        TrialResult 0
        {
            PassFail Fail;
            TrialAction __shared__::TpRule.MTT_Rule("Next","Exit");
            Return 0;
        }
        TrialResult 1
        {
            PassFail Pass;
            TrialAction "Exit";
            Return 1;
        }
        TrialResult 2
        {
            PassFail Fail;
            TrialAction __shared__::TpRule.MTT_Rule("Next","Exit");
            Return 0;
        }
        TrialResult 3
        {
            PassFail Fail;
            TrialAction __shared__::TpRule.MTT_Rule("Next","Exit");
            Return 0;
        }
        TrialResult 4
        {
            PassFail Fail;
            TrialAction __shared__::TpRule.MTT_Rule("Next","Exit");
            Return 0;
        }
        TrialResult 5
        {
            PassFail Fail;
            TrialAction __shared__::TpRule.MTT_Rule("Next","Exit");
            Return 0;
        }
    }
}

