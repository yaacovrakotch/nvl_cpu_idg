		}
		Result -1
		{
			Property PassFail = "Fail";
			SetBin __BIN__;
			Return -1;
		}
		Result 0
		{
			Property PassFail = "Fail";
			IncrementCounters __CTR__;
			Return 1;
		}
		Result 1
		{
			Property PassFail = "Pass";
			Return 1;
		}
		Result 2
		{
			Property PassFail = "Fail";
			IncrementCounters __CTR__;
			Return 1;
		}
		Result 3
		{
			Property PassFail = "Fail";
			IncrementCounters __CTR__;
			Return 1;
		}
		Result 4
		{
			Property PassFail = "Fail";
			IncrementCounters __CTR__;
			Return 1;
		}
		Result 5
		{
			Property PassFail = "Fail";
			IncrementCounters __CTR__;
			Return 1;
		}
	}
}
