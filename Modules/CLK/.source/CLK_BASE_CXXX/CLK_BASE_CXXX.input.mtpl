CSharpTest CsioCmemTC VREFTRIM_X_CMEM_K_`MinSubflow`_TAP_X_MIN_X_40_HVM `s52c exclude`
{
    Patlist = "clk_cpu_x_vreftrim_list";
    PlistConfigurationFile = GetEnvironmentVariable("`patmodify path`")+"/clk_cpu_x_vreftrim_list.plist.json";
    PrePlist = "`preplist_NOM`";
    IpConfigurationFile = "./InputFiles/clk.cpu.ip_map.`_BomGroupName``C0`.json";
    LimitsConfigurationFile = "./InputFiles/clk.`_TcgProduct`.limits.csv";
    PlistConfigSet = "clk_cpu_x_vreftrim_list";
    FunctionCall = "Ljpll_4p0_VrefTrim";
    EdcEnable = `TestPlanName`::`TestPlanName`.MIN_DATA;
    KillDecode = "ENABLED";
    CtvCapturePins = "`TDO`";
    LevelsTc = "`TestPlanName`::cpu_clk_override_distnom_sharedmin_lvl";
    TimingsTc = "`timing_prefix``timing_group`_mts100_tstprtclk50_tck100";
    PreInstance = "Call(ReadSpecSet(--levels `TestPlanName`::cpu_clk_override_distnom_sharedmin_lvl --name `level_vnnaon` --gsds G.U.D.clk_cpu_vreftrim_vnnaon --print))";
    `sds executed`
}
