Version 1.0;

ProgramStyle = Modular;

TestPlan `TestPlanName`;

Import `_ModuleFolderName`.usrv;
Import `_ModuleFolderName`_Levels.tcg;


#Test Counter Definition removed as part of bin/counter generator update.


####################################### INIT #######################################

CSharpTest PrimePatConfigTestMethod CLK_X_PATMOD_K_`INIT`_X_X_X_X_CPU
{
    ConfigurationFile = "./InputFiles/clk.cpu.clklineitem.setpoints`product`.json";
    SetPoint = `INIT_setpoint`;
    InstanceSummaryMode = "Enabled";
    `class unbypassed`
}

Flow `TestPlanName`_INIT @INIT `sds class flow only`
{
    FlowItem CLK_X_PATMOD_K_INIT_X_X_X_X_CPU CLK_X_PATMOD_K_`INIT`_X_X_X_X_CPU @EDC
    {
        Result -2 { Property PassFail = "Fail"; Return -2; }
        Result -1 { Property PassFail = "Fail"; Return -1; }
        Result 0  { Property PassFail = "Fail"; Return 0; }
        Result 1 { Property PassFail = "Pass"; Return 1; }
    }
}
####################################### VMIN #######################################
Flow `MinComposite`_BBS
{
    FlowItem RESETCHECK_X_CMEM_E_`MinSubflow`_TAP_X_MIN_X_40_BBS RESETCHECK_X_CMEM_E_`MinSubflow`_TAP_X_MIN_X_40_BBS @EDC
    {
        Result -2 { Property PassFail = "Fail"; Return -2; }
        Result -1 { Property PassFail = "Fail"; Return -1; }
        Result 0 { Property PassFail = "Fail"; GoTo CONFIGREAD_X_CMEM_E_`MinSubflow`_TAP_X_MIN_X_40_BBS; }
        Result 1 { Property PassFail = "Pass"; GoTo CONFIGREAD_X_CMEM_E_`MinSubflow`_TAP_X_MIN_X_40_BBS; }
        Result 2 { Property PassFail = "Fail"; GoTo CONFIGREAD_X_CMEM_E_`MinSubflow`_TAP_X_MIN_X_40_BBS; }
        Result 3 { Property PassFail = "Fail"; GoTo CONFIGREAD_X_CMEM_E_`MinSubflow`_TAP_X_MIN_X_40_BBS; }
        Result 4 { Property PassFail = "Fail"; GoTo CONFIGREAD_X_CMEM_E_`MinSubflow`_TAP_X_MIN_X_40_BBS; }
        Result 5 { Property PassFail = "Fail"; GoTo CONFIGREAD_X_CMEM_E_`MinSubflow`_TAP_X_MIN_X_40_BBS; }
    }
    FlowItem CONFIGREAD_X_CMEM_E_`MinSubflow`_TAP_X_MIN_X_40_BBS CONFIGREAD_X_CMEM_E_`MinSubflow`_TAP_X_MIN_X_40_BBS @EDC
    {
        Result -2 { Property PassFail = "Fail"; Return -2; }
        Result -1 { Property PassFail = "Fail"; Return -1; }
        Result 0 { Property PassFail = "Fail"; GoTo STATUSREAD_X_CMEM_E_`MinSubflow`_TAP_X_MIN_X_40_BBS; }
        Result 1 { Property PassFail = "Pass"; GoTo STATUSREAD_X_CMEM_E_`MinSubflow`_TAP_X_MIN_X_40_BBS; }
    }
    FlowItem STATUSREAD_X_CMEM_E_`MinSubflow`_TAP_X_MIN_X_40_BBS STATUSREAD_X_CMEM_E_`MinSubflow`_TAP_X_MIN_X_40_BBS @EDC
    {
        Result -2 { Property PassFail = "Fail"; Return -2; }
        Result -1 { Property PassFail = "Fail"; Return -1; }
        Result 0  { Property PassFail = "Fail"; Return 1; }
        Result 1 { Property PassFail = "Pass"; Return 1; }
    }
}

CSharpTest DDGFunctionalTC RESETCHECK_X_CMEM_E_`MinSubflow`_TAP_X_MIN_X_40_BBS
{
    Patlist = "clk_cpu_x_resetcheck_list";
    FailuresToCapturePerPattern = 1;
    FailuresToCaptureTotal = 1;
    MaxFailuresPerPatternToItuff = 1;
    MaxFailuresToItuff = 1;
    LevelsTc = "`TestPlanName`::cpu_clk_override_distnom_sharedmin_lvl";
    TimingsTc = "`timing_prefix``timing_group`_mts100_tstprtclk50_tck100";
    `PHMBypassPRIME`
}
CSharpTest CsioCmemTC CONFIGREAD_X_CMEM_E_`MinSubflow`_TAP_X_MIN_X_40_BBS
{
    Patlist = "clk_cpu_x_configread_list";
    PlistConfigurationFile = GetEnvironmentVariable("`patmodify path`")+"/clk_cpu_x_configread_list.plist.json";
    PrePlist = "`preplist_NOM`";
    IpConfigurationFile = "./InputFiles/clk.cpu.ip_map.`_BomGroupName``C0`.json";
    LimitsConfigurationFile = "./InputFiles/clk.`_TcgProduct`.limits.csv";
    PlistConfigSet = "clk_cpu_x_configread_list";
    FunctionCall = "Generic_RegRead";
    EdcEnable = `TestPlanName`::`TestPlanName`.MIN_DATA;
    KillDecode = "ENABLED";
    CtvCapturePins = "`TDO`";
    LevelsTc = "`TestPlanName`::cpu_clk_override_distnom_sharedmin_lvl";
    TimingsTc = "`timing_prefix``timing_group`_mts100_tstprtclk50_tck100";
    `PHMBypassPRIME`
}
CSharpTest CsioCmemTC STATUSREAD_X_CMEM_E_`MinSubflow`_TAP_X_MIN_X_40_BBS
{
    Patlist = "clk_cpu_x_statusread_list";
    PlistConfigurationFile = GetEnvironmentVariable("`patmodify path`")+"/clk_cpu_x_statusread_list.plist.json";
    PrePlist = "`preplist_NOM`";
    IpConfigurationFile = "./InputFiles/clk.cpu.ip_map.`_BomGroupName``C0`.json";
    LimitsConfigurationFile = "./InputFiles/clk.`_TcgProduct`.limits.csv";
    PlistConfigSet = "clk_cpu_x_statusread_list";
    FunctionCall = "Generic_RegRead";
    EdcEnable = `TestPlanName`::`TestPlanName`.MIN_DATA;
    KillDecode = "ENABLED";
    CtvCapturePins = "`TDO`";
    LevelsTc = "`TestPlanName`::cpu_clk_override_distnom_sharedmin_lvl";
    TimingsTc = "`timing_prefix``timing_group`_mts100_tstprtclk50_tck100"; 
    `PHMBypassPRIME`
}

