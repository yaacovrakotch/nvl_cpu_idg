CSharpTest CsioCmemTC AFSDELTAF_FLL_CMEM_E_`DebugSubFlow`_TAP_X_MIN_X_40_TDV
{
    Patlist = "`patlist_prefix`clk_cpu_x_fllafsdeltaf_list";
    PlistConfigurationFile = GetEnvironmentVariable("`patmodify path`")+"/clk_cpu_x_fllafsdeltaf_list.plist.json";
    PrePlist = "`preplist_NOM`";
