CSharpTest CsioCmemTC SPETRIM_PLL_CMEM_E_`DebugSubFlow`_TAP_X_MIN_X_40_TDV
{
    Patlist = "`patlist_prefix`clk_cpu_x_spetrim_list";
    PlistConfigurationFile = GetEnvironmentVariable("`patmodify path`")+"/clk_cpu_x_spetrim_list.plist.json";
    PrePlist = "`preplist_MIN`";
    IpConfigurationFile = "./InputFiles/clk.cpu.ip_map.`_BomGroupName``C0`.json";
    LimitsConfigurationFile = "./InputFiles/clk.`_TcgProduct`.limits.csv";
    PlistConfigSet = "clk_cpu_x_spetrim_list";
    FunctionCall = "Ljpll_4p0_SpeTrim";
    EdcEnable = "ENABLED";
    KillDecode = "DISABLED";
    CtvCapturePins = "`TDO`";
    LevelsTc = "`TestPlanName`::`TestCondition_min`";
    TimingsTc = "`timing_prefix``timing_group`_mts100_tstprtclk50_tck100";
    PostInstance = "`smartTC_disable`";
    BypassPort = -1;
}
CSharpTest CsioCmemTC LOCK100X_X_CMEM_E_`DebugSubFlow`_TAP_X_MIN_X_40_TDV
{
    Patlist = "`patlist_prefix`clk_cpu_x_100xlock40_list";
    PlistConfigurationFile = GetEnvironmentVariable("`patmodify path`")+"/clk_cpu_x_100xlock40_list.plist.json";
    PrePlist = "`preplist_MIN`";
    IpConfigurationFile = "./InputFiles/clk.cpu.ip_map.`_BomGroupName``C0`.json";
    LimitsConfigurationFile = "./InputFiles/clk.`_TcgProduct`.limits.csv";
    PlistConfigSet = "clk_cpu_x_100xlock40_list";
    FunctionCall = "Ljpll_4p0_Lock100x";
    EdcEnable = "ENABLED";
    KillDecode = "DISABLED";
    CtvCapturePins = "`TDO`";
    LevelsTc = "`TestPlanName`::`TestCondition_min`";
    TimingsTc = "`timing_prefix``timing_group`_mts100_tstprtclk50_tck100";
    BypassPort = -1;
}
CSharpTest VminTC PERFREQ_PNC0_VMIN_E_`DebugSubFlow`_TAP_X_MIN_X_40_TDV
{
    Patlist = "`patlist_prefix`clk_cpu_x_lockvmin_pnc0_list";
    LevelsTc = "`TestPlanName`::`TestCondition_min`";
    TimingsTc = "`timing_prefix``timing_group`_mts100_tstprtclk50_tck100";
    EndVoltageLimits = "0.85";
    StartVoltages = "0.4";
    StepSize = 0.02;
    TestMode = "SingleVmin";
    PatternNameCounterIndexes = "104,105,106,107";
    VoltageConverter = "`VminTC VoltageConverter`";
    VoltageTargets = "`VminTC VoltageTargets CORE0`";
