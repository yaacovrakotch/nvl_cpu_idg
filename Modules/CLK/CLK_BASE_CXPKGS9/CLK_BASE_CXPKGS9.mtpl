CSharpTest PrimePatConfigTestMethod CLK_X_PATMOD_K_INIT_X_X_X_X_CPU
{
	ConfigurationFile = "./InputFiles/clk.cpu.clklineitem.setpoints_S52C.json";
	SetPoint = "clk_ringfreq_0_4GHz,clk_corefreq_0_4GHz,clk_atomfreq_0_4GHz,clk_throttle_done_detected_core";
	InstanceSummaryMode = "Enabled";
	BypassPort = __shared__::TpRule.If_PHM(1, -1);
}
