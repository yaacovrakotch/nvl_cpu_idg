{
	Patlist = "clk_cpu_x_resetcheck_list";
	FailuresToCapturePerPattern = 1;
	FailuresToCaptureTotal = 1;
	MaxFailuresPerPatternToItuff = 1;
	MaxFailuresToItuff = 1;
	LevelsTc = "CLK_BASE_CXXX::cpu_clk_override_distnom_sharedmin_lvl";
	TimingsTc = "CPU_IP_BASE::cpu_fun_timing_mts100_tstprtclk50_tck100";
	BypassPort = __shared__::TpRule.If_PHM(1, -1);
}
CSharpTest CsioCmemTC CONFIGREAD_X_CMEM_E_STARTANA1CPU_TAP_X_MIN_X_40_BBS
{
	Patlist = "clk_cpu_x_configread_list";
	PlistConfigurationFile = GetEnvironmentVariable("CLK_BASE_CXPKGS9__PATMODIFY_PATH")+"/clk_cpu_x_configread_list.plist.json";
	PrePlist = "VoltageConverter(--fivrcondition NOM --dlvrpins VCCIA --overrides CCF:0.675,CORE0:0.675,CORE1:0.675,CORE2:0.675,CORE3:0.675,ATOM0:0.675,ATOM1:0.675,ATOM2:0.675,ATOM3:0.675,CCF1:0.675,CORE01:0.675,CORE11:0.675,CORE21:0.675,CORE31:0.675,ATOM01:0.675,ATOM11:0.675,ATOM21:0.675,ATOM31:0.675)";
	IpConfigurationFile = "./InputFiles/clk.cpu.ip_map.CLASS_S52C.json";
	LimitsConfigurationFile = "./InputFiles/clk.nvlcpu_i8ga0.limits.csv";
	PlistConfigSet = "clk_cpu_x_configread_list";
	FunctionCall = "Generic_RegRead";
	EdcEnable = CLK_BASE_CXXX::CLK_BASE_CXXX.MIN_DATA;
	KillDecode = "ENABLED";
	CtvCapturePins = "CPU_TDO,CPU1_TDO";
