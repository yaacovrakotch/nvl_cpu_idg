CSharpTest RunCallback CTRL_X_UF_E_INIT_X_X_X_X_SCNCORE_APEXTC
{
    BypassPort = __shared__::TpRule.If_DS0_DS1_M(-1, -1, BYPASS_PARAMETER.APEXTC_BYPASS, 1);
    Callback = "ReadFrequencyPatConfigFile";
    Parameters = __shared__::TpRule.If_DS0_DS1_M(GetEnvironmentVariable("~HDMT_TP_BASE_DIR") + "./Modules/SCN/SCN_CORE_CX816/InputFiles/ApexTC_Input_Config_N2P.json", GetEnvironmentVariable("~HDMT_TP_BASE_DIR") + "./Modules/SCN/SCN_CORE_CX816/InputFiles/ApexTC_Input_Config.json", GetEnvironmentVariable("~HDMT_TP_BASE_DIR") + "./Modules/SCN/SCN_CORE_CX816/InputFiles/ApexTC_Input_Config_N2P.json", GetEnvironmentVariable("~HDMT_TP_BASE_DIR") + "./Modules/SCN/SCN_CORE_CX816/InputFiles/ApexTC_Input_Config_N2P.json");
}

CSharpTest VminTC STUCKAT_CORE_SB_K_BEGINCPU_X_CR_NOM_X_F1_ALLCORE
{
    Patlist = __shared__::TpRule.If_DS0_DS1_M("scn_cdie_begincpu_occ_stuckat_ssn400_edt_classhvm_list","scn_cdie_begincpu_occ_stuckat_ssn400_edt_classhvm_list","scn_cdie_begincpu_occ_stuckat_ssn400_edt_classhvm_list","scn_cdie_begincpu_occ_stuckat_ssn400_edt_classhvm_list");
    LevelsTc = __shared__::TpRule.If_DS0_DS1_M("SCN_CORE_CX816::cpu_all_bf_x_x_ipc_lvl_CPU_BFUNC_SCNCORE_OVERRIDE_nom","SCN_CORE_CX816::cpu_all_bf_x_x_ipc_lvl_CPU_BFUNC_SCNCORE_OVERRIDE_nom","SCN_CORE_CX816::cpu_all_bf_x_x_ipc_lvl_CPU_BFUNC_SCNCORE_OVERRIDE_nom","SCN_CORE_CX816::cpu_all_bf_x_x_ipc_lvl_CPU_BFUNC_SCNCORE_OVERRIDE_nom");
    TimingsTc = __shared__::TpRule.If_DS0_DS1_M("SCN_CORE_CX816::cpu_hvm_timing_mts1500_tstprtclk750_tck93p75_B0OVERRIDE1500","SCN_CORE_CX816::cpu_fun_timing_mts800_tstprtclk400_tck100_OVERRIDE800","SCN_CORE_CX816::cpu_hvm_timing_mts1500_tstprtclk750_tck93p75_HXB0OVERRIDE1500","SCN_CORE_CX816::cpu_hvm_timing_mts1500_tstprtclk750_tck93p75_HXB0OVERRIDE1500");
    BaseNumbers = "13004";
    BypassPort = -1;
    EndVoltageLimits = "0.9";
    ExecutionMode = "SearchWithScoreboard";
    FailCaptureCount = toInteger(999);
    FeatureSwitchSettings = "fivr_mode_on,disable_masked_targets,print_per_target_increments,print_scoreboard_counters";
    FivrCondition = "NOM_CCF_CORE";
    ForwardingMode = "InputOutput";
    LogLevel = "Disabled";
    MaxFailsNum = toInteger(__shared__::Specs.VMX_MAX_FAILS);
    PatternNameCounterIndexes = "1,2,3,4,5,6,7";
    PinMap = "SCN_CORE";
    PostInstance = "";
    PreInstance = "";
    RecoveryMode = "RecoveryPort";
    RecoveryOptions = __shared__::Recovery_Single.F1F4_recovery_opt_CR;
    RecoveryTrackingIncoming = "CR";
    RecoveryTrackingOutgoing = "CR";
    ScoreboardEdgeTicks = toInteger(__shared__::Specs.VMX_EDGE_TICK);
    SetPointsPlistMode = "Local";
    SetPointsPlistParamName = "Patlist";
    SetPointsPostInstance = PSPOST.CR_F1;
    SetPointsPreInstance = PSPRE.CR_F1+","+"MCdrv:corefreq:"+__shared__::FlowMatrixSingular.CR_F1_FREQ+"GHz";
    StartVoltages = "0.9";
    StepSize = toDouble(0.01);
    TestMode = "MultiVmin";
    VoltageConverter = "--dlvrpins VCCIA --expressions " + DROPOUT.CR_F1;
    VoltageTargets = "CORE3,CORE2,CORE1,CORE0";
}

MultiTrialTest ATSPEED_CORE_VMIN_K_FMINXCR_X_CR_FMIN_X_FREQ_ALLCORE_MTT
{
    # KILL ATSPEED FMINXCR
    TrialVariable CPU_TRIALS::FlowDomain.CORE;
    TrialVariableExitAction "Continue";
    CSharpTrialTest VminTC "ATSPEED_CORE_VMIN_K_FMINXCR_X_CR_FMIN_" + __shared__::CustomFlowMatrixSpecs.CR_FMIN_MHz + "_ALLCORE"
    {
        Patlist = __shared__::TpRule.If_DS0_DS1_M("scn_cdie_fminxcr_occ_atspeed_ssn400_edt_classhvm_list","scn_cdie_fminxcr_occ_atspeed_ssn400_edt_classhvm_list","scn_cdie_fminxcr_occ_atspeed_ssn400_edt_classhvm_list","scn_cdie_fminxcr_occ_atspeed_ssn400_edt_classhvm_list");
        LevelsTc = __shared__::TpRule.If_DS0_DS1_M("SCN_CORE_CX816::cpu_all_bf_x_x_ipc_lvl_CPU_BFUNC_SCNCORE_OVERRIDE_nom","SCN_CORE_CX816::cpu_all_bf_x_x_ipc_lvl_CPU_BFUNC_SCNCORE_OVERRIDE_nom","SCN_CORE_CX816::cpu_all_bf_x_x_ipc_lvl_CPU_BFUNC_SCNCORE_OVERRIDE_nom","SCN_CORE_CX816::cpu_all_bf_x_x_ipc_lvl_CPU_BFUNC_SCNCORE_OVERRIDE_nom");
        TimingsTc = __shared__::TpRule.If_DS0_DS1_M("SCN_CORE_CX816::cpu_hvm_timing_mts1500_tstprtclk750_tck93p75_B0OVERRIDE1500","SCN_CORE_CX816::cpu_fun_timing_mts800_tstprtclk400_tck100_OVERRIDE800","SCN_CORE_CX816::cpu_hvm_timing_mts1500_tstprtclk750_tck93p75_HXB0OVERRIDE1500","SCN_CORE_CX816::cpu_hvm_timing_mts1500_tstprtclk750_tck93p75_HXB0OVERRIDE1500");
        BaseNumbers = "13005";
        BypassPort = -1;
        CornerIdentifiers = "CR3@F1,CR2@F1,CR1@F1,CR0@F1";
        DtsConfiguration = __shared__::TpRule.If_DS0_DS1_M("ALL_CDIE_S28C_N2P","ALL_CDIE_S52C","ALL_CDIE_S28C_N2P","ALL_CDIE_S28C");
        EndVoltageLimits = __shared__::FlowMatrixSingular.CR_LFM_VMIN_RAIN_KILL;
        ExecutionMode = "SearchWithScoreboard";
        FailCaptureCount = toInteger(5);
        FeatureSwitchSettings = "fivr_mode_on,disable_masked_targets,print_per_target_increments,print_scoreboard_counters";
        FivrCondition = "NOM_CCF_CORE";
        TrialParam FlowIndex = __shared__::FlowMatrix.FlowIndex;
        FlowIndexCallbackName = "";
        ForwardingMode = "Input";
        InitialMaskBits = "";
        LimitGuardband = toString(__shared__::GBVars.FminLimitGuardband);
        LogLevel = "Disabled";
        MaskPins = "";
        MaxFailsNum = toInteger(__shared__::Specs.CHK_MAX_FAILS);
        PatternNameCounterIndexes = "1,2,3,4,5,6,7";
        PinMap = "SCN_CORE_AS";
        PostInstance = "";
        PreInstance = "";
        RecoveryMode = "NoRecovery";
        RecoveryOptions = "";
        RecoveryTrackingIncoming = "CR";
        RecoveryTrackingOutgoing = "";
        ScoreboardEdgeTicks = toInteger(__shared__::Specs.CHK_EDGE_TICK);
        SetPointsPlistMode = "Local";
        SetPointsPlistParamName = "Patlist";
        SetPointsPostInstance = PSPOST.CR_FMIN;
        SetPointsPreInstance = PSPRE.CR_FMIN+","+"MCdrv:corefreq:"+__shared__::FlowMatrixSingular.CR_FMIN+"GHz";
        StartVoltages = __shared__::FlowMatrixSingular.CR_LOW_SEARCH_VALUE;
        StartVoltagesForRetry = __shared__::QNRTpRuleShared.If_PseudoVminForwarding(__shared__::QNRUsrvShared.StartVoltagesForRetry , "");
        StartVoltagesOffset = __shared__::QNRTpRuleShared.If_PseudoVminForwarding(__shared__::QNRUsrvShared.StartVoltagesOffset , "");
        StepSize = toDouble(__shared__::FlowMatrixSingular.CR_SEARCH_RESOLUTION);
        TestMode = "MultiVmin";
        VoltageConverter = "--railconfigurations CDIE_CORE_NBLCTRL3 CDIE_CORE_NBLCTRL2 CDIE_CORE_NBLCTRL1 CDIE_CORE_NBLCTRL0 --dlvrpins VCCIA --expressions " + DROPOUT.CR_FMIN;
        VoltageTargets = "CORE3,CORE2,CORE1,CORE0";
        VoltagesOffset = "GBVars.VoltageOffset";
        TrialResult -2
        {
            PassFail Fail;
            TrialAction "Exit";
            Return -2;
        }
        TrialResult -1
        {
            PassFail Fail;
            TrialAction "Exit";
            Return -1;
        }
        TrialResult 0
        {
            PassFail Fail;
            TrialAction __shared__::TpRule.MTT_Rule("Next","Exit");
            Return 0;
        }
        TrialResult 1
        {
            PassFail Pass;
            TrialAction "Exit";
            Return 1;
        }
        TrialResult 2
        {
            PassFail Fail;
            TrialAction __shared__::TpRule.MTT_Rule("Next","Exit");
            Return 2;
        }
        TrialResult 3
        {
            PassFail Pass;
            TrialAction __shared__::TpRule.MTT_Rule("Next","Exit");
            Return 3;
        }
        TrialResult 4
        {
            PassFail Fail;
            TrialAction __shared__::TpRule.MTT_Rule("Next","Exit");
            Return 4;
        }
        TrialResult 5
        {
            PassFail Fail;
            TrialAction __shared__::TpRule.MTT_Rule("Next","Exit");
            Return 5;
        }
    }
}

