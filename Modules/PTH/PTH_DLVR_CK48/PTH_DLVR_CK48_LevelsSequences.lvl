Levels DLVR_VBUMP_VCCIA
{
	VCCIA
	{
		FreeDriveTime = 5mS;
		IClampHi = 162A;
		IClampLo = -45A;
		IRange = "IR24A";
		OPModeCheck = "VSIM";
		VForce = p_vbump_val_ia;
		VSlewStepRatio = 60;
	}
}

