        }
    ],
    "DC": [
        {
            "Domains": ["CORE0P"],
            "Measurements": {
                "CPU_CORE0P_DVDACG": {
                    "Pin": "IPC::CPU_CORE0_DLVROUT",
                    "Average": 10,
                    "Expect": 90
                }
            },
            "Equations": [
                {
                    "Name": "CPU_LINEARFIT_{DOMAIN}",
                    "Expression": "LinearFit(SelectArrayElements([CPU_{DOMAIN}_DVDACG],'0-8', ','), SelectArrayElements([DVDACG_TGT], '0-8', ','), ',')",
                    "SaveResult": true,
                    "DatalogFormat": "STR"
                }
            ]
        },
        {
            "Domains": ["0","1","2","3","4","5","6","7","8"],
            "Token": "DVDACG_CORE0P",
            "Equations": [
                {
                    "Expression": "Round(SelectArrayElement([CPU_CORE0P_DVDACG], {DOMAIN}), 4)",
                    "SaveToSharedStorage": "CPU_CORE0P_DVDACG_{DOMAIN}",
                    "DatalogFormat": "DBL"
                }
            ]
        },
        {
            "Domains": ["CORE0P"],
            "Equations": [
                {
                    "Expression": "ToInt32(Round(GetDelimitedData([CPU_LINEARFIT_CORE0P], ',', 1) * 2048, 0))",
                    "DatalogFormat": "INT",
                    "SaveToSharedStorage": "CPU_CORE0P_DLVR_DAC_CAL_SLOPE"
                },
                {
                    "Expression": "ToInt32(Round(ToDouble(GetDelimitedData([CPU_LINEARFIT_CORE0P], ',', 0)) * 2/0.0025, 0))",
                    "SaveToSharedStorage": "CPU_CORE0P_DLVR_DAC_CAL_OFFSET_1",
                    "DatalogFormat": "INT"
                },
                {
                    "Expression": "ToDouble(GetDelimitedData([CPU_LINEARFIT_CORE0P], ',', 2))",
                    "SaveToSharedStorage": "CPU_CORE0P_DLVR_DAC_CAL_R2"
                }
            ]
        }
    ]
}