{
    "IndexAllMeasurements": false,
    "CONSTANTS": {
        "DVDACG_TGT": "1.2, 1.1, 1.0, 0.9, 0.8, 0.7, 0.6, 0.5, 0.4"
    },
    "CTV": [
        {
            "PinName": "CPU_TDO",
            "Equations": [
                {
                    "RegName": "AON",
                    "StartBit": 0,
                    "Length": 9,
                    "SaveResult": true,
                    "Equation": "((Bin2Dec([This])/2)-64)",
                    "SaveToSharedStorage": "AON"
                }
            ]
        }
    ],
    "DC": [
        {
            "Domains": ["ATOM0","ATOM1"],
            "Measurements": {
                "CPU_ATOM0_DVDACG": {
                    "Pin": "IPC::CPU_ATOM0_DLVROUT",
                    "Average": 10,
                    "Expect": 90
                },
                "CPU_ATOM1_DVDACG": {
                    "Pin": "IPC::CPU_ATOM1_DLVROUT",
                    "Average": 10,
                    "Expect": 90
                }
            },
            "Equations": [
                {
                    "Name": "CPU_LINEARFIT_{DOMAIN}",
                    "Expression": "LinearFit(SelectArrayElements([CPU_{DOMAIN}_DVDACG],'0-8', ','), SelectArrayElements([DVDACG_TGT], '0-8', ','), ',')",
                    "SaveResult": true,
                    "DatalogFormat": "STR"
                }
            ]
        },
        
        {
           "Domains": ["0","1","2","3","4","5","6","7","8"],
           "Token": "DVDACG_ATOM0",
            "Equations": [
                {
                    "Expression": "Round(SelectArrayElement([CPU_ATOM0_DVDACG], {DOMAIN}), 4)",
                    "SaveToSharedStorage": "CPU_ATOM0_DVDACG_{DOMAIN}",
			"DatalogFormat": "DBL"
                }
            ]
        },
        {
            "Domains": ["ATOM0"],
            "Equations": [
                {
                    "Expression": "ToInt32(Round(GetDelimitedData([CPU_LINEARFIT_ATOM0], ',', 1) * 2048, 0))",
                    "DatalogFormat": "INT",
                    "SaveToSharedStorage": "CPU_ATOM0_DLVR_DAC_CAL_SLOPE"
                },
                {
                    "Expression": "ToInt32(Round(ToDouble(GetDelimitedData([CPU_LINEARFIT_ATOM0], ',', 0)) * 2/0.0025, 0))",
                    "SaveToSharedStorage": "CPU_ATOM0_DLVR_DAC_CAL_OFFSET_1",
                    "DatalogFormat": "INT"
                },
                {
                    "Expression": "ToDouble(GetDelimitedData([CPU_LINEARFIT_ATOM0], ',', 2))",
                    "SaveToSharedStorage": "CPU_ATOM0_DLVR_DAC_CAL_R2"
                }
            ]
        },
        {
            "Domains": ["0","1","2","3","4","5","6","7","8"],
           "Token": "DVDACG_ATOM1",
            "Equations": [
                {
                    "Expression": "Round(SelectArrayElement([CPU_ATOM1_DVDACG], {DOMAIN}), 4)",
                    "SaveToSharedStorage": "CPU_ATOM1_DVDACG_{DOMAIN}",
		    "DatalogFormat": "DBL"
                }
            ]
        },
        {
            "Domains": ["ATOM1"],
            "Equations": [
                {
                    "Expression": "ToInt32(Round(GetDelimitedData([CPU_LINEARFIT_ATOM1], ',', 1) * 2048, 0))",
                    "DatalogFormat": "INT",
                    "SaveToSharedStorage": "CPU_ATOM1_DLVR_DAC_CAL_SLOPE"
                },
                {
                    "Expression": "ToInt32(Round(ToDouble(GetDelimitedData([CPU_LINEARFIT_ATOM1], ',', 0)) * 2/0.0025, 0))",
                    "SaveToSharedStorage": "CPU_ATOM1_DLVR_DAC_CAL_OFFSET_1",
                    "DatalogFormat": "INT"
                },
                {
                    "Expression": "ToDouble(GetDelimitedData([CPU_LINEARFIT_ATOM1], ',', 2))",
                    "SaveToSharedStorage": "CPU_ATOM1_DLVR_DAC_CAL_R2"
                }
            ]
        }
    ]
}