    SelectorRuleCollection  MIO_HPTP_CXPKGS7_Rules
{
	SelectorRule If_AHMT(yes, no) ####By checking locn and process####
	{
		yes => ( __shared__::SCVars.SC_LOCN == "6167" &&  __shared__::SCVars.SC_CURRENT_PROCESS_TYPE == "CLASSHOT") || ( __shared__::SCVars.SC_LOCN == "5167" &&  __shared__::SCVars.SC_CURRENT_PROCESS_TYPE == "CLASSHOT") || (MIO_HPTP_CXPKGS7.bypass_margin_check_scan_UV == 1);
		no;
	}

    SelectorRule If_AHMT_S28_S28B_S16(Outcome1, Outcome2, Outcome3, Outcome4, Outcome5)
	{
		Outcome1 => ( __shared__::SCVars.SC_LOCN == "6167" &&  __shared__::SCVars.SC_CURRENT_PROCESS_TYPE == "CLASSHOT") || ( __shared__::SCVars.SC_LOCN == "5167" &&  __shared__::SCVars.SC_CURRENT_PROCESS_TYPE == "CLASSHOT") || (MIO_HPTP_CXPKGS7.bypass_margin_check_scan_UV == 1);
        Outcome2 => GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S28C";
        Outcome3 => GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S28CB";
		Outcome4 => GetEnvironmentVariable("BOMGROUP") == "CLASS_NVL_S16C";
		Outcome5;
	}
}