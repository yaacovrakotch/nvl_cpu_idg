<?xml version="1.0" encoding="utf-8"?>
<Project>
  <PropertyGroup>
    <ManagePackageVersionsCentrally>true</ManagePackageVersionsCentrally>
    <CentralPackageVersionOverrideEnabled>false</CentralPackageVersionOverrideEnabled>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
  </PropertyGroup>
  <!--This file will be generated by the Prime MetaNuGet package to allow settings of specific version compatible with this version of Prime-->
  <Import Project="$(MSBuildThisFileDirectory)Prime.Release.Settings.props" Condition="Exists('$(MSBuildThisFileDirectory)Prime.Release.Settings.props')" />
  <ItemGroup>
    <PackageVersion Include="CommandLineParser" Version="2.9.1" />
    <PackageVersion Include="CoreCLR-NCalc" Version="2.2.113" />
    <PackageVersion Include="coverlet.collector" Version="1.2.0" />
    <PackageVersion Include="DataTablePrettyPrinter" Version="0.2.0" />
    <PackageVersion Include="DDG.AllLibrary.Release" Version="$(DDGVersion)" />
    <PackageVersion Include="DDG.TestMethods.CtvDecoderSpm.Release" Version="$(DDGVersion)" />
    <PackageVersion Include="FuseLogicEngineISeed" Version="1.2.4" Condition="$(TargetFrameWork)=='net462'" />
    <PackageVersion Include="FuseLogicEngineCore" Version="1.3.9" Condition="$(TargetFrameWork)=='net462'" />
    <PackageVersion Include="FuseLogicEngineISeed" Version="1.2.5.1-tos4" Condition="$(TargetFrameWork)!='net462'" />
    <PackageVersion Include="FuseLogicEngineCore" Version="1.4.0.1-tos4" Condition="$(TargetFrameWork)!='net462'" />    
    <PackageVersion Include="MPE.MIT.ATE.TM.HashFunctions" Version="1.0.7" />
    <PackageVersion Include="MPE.MIT.ATE_TM.PrimePHGenerator" Version="[3.8.4,4.0.0)" />
    <PackageVersion Include="Prime" Version="$(PrimeVersion)" />
    <PackageVersion Include="Prime.UserCode.Settings" Version="$(UserCodeSettingsVersion)" />
    <PackageVersion Include="MathNet.Numerics" Version="5.0.0" />
    <PackageVersion Include="Microsoft.Automata.SRM" Version="1.2.2-PRIME" />
    <PackageVersion Include="Microsoft.CodeAnalysis.CSharp" Version="4.5.0" />
    <PackageVersion Include="Microsoft.Extensions.DependencyInjection" Version="8.0.0" />
    <PackageVersion Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="8.0.1" />
    <PackageVersion Include="Microsoft.ML" Version="1.6.0" />
    <PackageVersion Include="Microsoft.ML.CpuMath" Version="1.6.0" />
    <PackageVersion Include="Microsoft.NET.Test.Sdk" Version="17.2.0" />
    <PackageVersion Include="Moq" Version="4.18.4" />
    <PackageVersion Include="Moq.AutoMock" Version="3.5.0" />
    <PackageVersion Include="MSTest.TestAdapter" Version="2.2.8" />
    <PackageVersion Include="MSTest.TestFramework" Version="2.2.8" />
    <PackageVersion Include="Newtonsoft.Json" Version="12.0.3" Condition="$(TargetFrameWork)=='net462'" />
    <PackageVersion Include="Newtonsoft.Json" Version="13.0.3" Condition="$(TargetFrameWork)!='net462'"/>
    <PackageVersion Include="ncalc" Version="1.3.8" />
    <PackageVersion Include="NJsonSchema-PRIME-CUSTOM" Version="10.5.2" />
    <PackageVersion Include="Npgsql" Version="4.1.14" />
    <PackageVersion Include="org.matheval" Version="1.0.0.3" />
    <PackageVersion Include="StyleCop.Analyzers" Version="1.1.118" />
    <PackageVersion Include="System.Collections.Immutable" Version="1.6.0" Condition="$(TargetFrameWork)=='net462'"/>
    <PackageVersion Include="System.Collections.Immutable" Version="6.0.0" Condition="$(TargetFrameWork)!='net462'" />
    <PackageVersion Include="System.Data.SqlClient" Version="4.8.6" />
    <PackageVersion Include="System.Drawing.Common" Version="6.0.0" />
    <PackageVersion Include="System.Formats.Asn1" Version="6.0.1" />
    <PackageVersion Include="System.IO.Abstractions" Version="17.0.23" />
    <PackageVersion Include="System.IO.Abstractions.TestingHelpers" Version="17.0.23" />
    <PackageVersion Include="System.Management" Version="8.0.0" />
    <PackageVersion Include="System.Runtime.CompilerServices.Unsafe" Version="4.7.0" Condition="$(TargetFrameWork)=='net462'" />
    <PackageVersion Include="System.Runtime.CompilerServices.Unsafe" Version="6.0.0" Condition="$(TargetFrameWork)!='net462'" />
    <PackageVersion Include="System.Security.Cryptography.Pkcs" Version="6.0.5" />
    <PackageVersion Include="System.ServiceModel.Duplex" Version="6.0.0" />
    <PackageVersion Include="System.ServiceModel.Http" Version="6.2.0" />
    <PackageVersion Include="System.ServiceModel.Federation" Version="6.2.0" />
    <PackageVersion Include="System.ServiceModel.NetTcp" Version="6.2.0" />
    <PackageVersion Include="System.ServiceModel.Primitives" Version="6.2.0" />
    <PackageVersion Include="System.ServiceModel.Security" Version="6.0.0" />
    <PackageVersion Include="System.Text.Json" Version="4.6.0" Condition="$(TargetFrameWork)=='net462'" />
    <PackageVersion Include="System.Text.Json" Version="8.0.5" Condition="$(TargetFrameWork)!='net462'"/>
    <PackageVersion Include="System.Text.RegularExpressions" Version="4.3.1" />
    <PackageVersion Include="System.Threading.Tasks.Extensions" Version="4.5.4" />
    <PackageVersion Include="System.ValueTuple" Version="4.5.0" />
    <PackageVersion Include="UPS.Facade" Version="2439.0.0" />
  </ItemGroup>
</Project>